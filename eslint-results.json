lex: 1 }","line":67,"column":18,"nodeType":"ObjectExpression","endLine":67,"endColumn":70}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from 'react';\nimport {\n  View,\n  Text,\n  ScrollView,\n  ActivityIndicator,\n  TouchableOpacity,\n  StatusBar,\n} from 'react-native';\nimport { useSafeAreaInsets } from 'react-native-safe-area-context';\nimport Svg, { Path } from 'react-native-svg';\nimport { styles } from './styles';\nimport { colors } from '../../constants/colors';\nimport { useLanguage } from '../../contexts/LanguageContext';\nimport { usePrivacySettings } from '../../hooks/useSiteSettings';\n\ninterface PrivacyProps {\n  onBack?: () => void;\n}\n\nconst Privacy: React.FC<PrivacyProps> = ({ onBack }) => {\n  const { isRTL, language } = useLanguage();\n  const insets = useSafeAreaInsets();\n  const { data: privacyData, isLoading, error } = usePrivacySettings();\n\n  // Show loading state\n  if (isLoading) {\n    return (\n      <View style={styles.centerContainer}>\n        <StatusBar\n          backgroundColor=\"#00a19c\"\n          barStyle=\"light-content\"\n          translucent={false}\n        />\n        <ActivityIndicator size=\"large\" color={colors.primary} />\n        <Text style={[styles.loadingText, isRTL && styles.textRTL]}>\n          {isRTL ? 'в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ...' : 'Loading...'}\n        </Text>\n      </View>\n    );\n  }\n\n  // Show error state\n  if (error) {\n    return (\n      <View style={styles.centerContainer}>\n        <StatusBar\n          backgroundColor=\"#00a19c\"\n          barStyle=\"light-content\"\n          translucent={false}\n        />\n        <Text style={[styles.errorText, isRTL && styles.textRTL]}>\n          {isRTL ? 'в”ҳГјв•Әв”Өв”ҳГӨ в”ҳГјв”ҳГЁ в•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬' : 'Failed to load data'}\n        </Text>\n        <Text style={[styles.errorSubtext, isRTL && styles.textRTL]}>\n          {error.message}\n        </Text>\n      </View>\n    );\n  }\n\n  // Get content based on language\n  const content =\n    language === 'ar' ? privacyData?.contentAr : privacyData?.contentEn;\n\n  return (\n    <View style={{ flex: 1, backgroundColor: colors.backgroundLight }}>\n      <StatusBar\n        backgroundColor=\"#00a19c\"\n        barStyle=\"light-content\"\n        translucent={false}\n      />\n      <View style={{ height: insets.top, backgroundColor: colors.primary }} />\n      <View style={styles.container}>\n        <ScrollView\n          style={styles.scrollView}\n          contentContainerStyle={styles.contentContainer}\n          showsVerticalScrollIndicator={false}\n        >\n          {/* Hero Section with Title */}\n          <View style={styles.heroSection}>\n            {/* Back Button Container */}\n            <View\n              style={[\n                styles.backButtonContainer,\n                isRTL && styles.backButtonContainerRTL,\n              ]}\n            >\n              <TouchableOpacity\n                style={[styles.backButton, isRTL && styles.backButtonRTL]}\n                onPress={onBack}\n                activeOpacity={0.7}\n              >\n                <Svg width={24} height={24} viewBox=\"0 0 24 24\" fill=\"none\">\n                  <Path\n                    d=\"M15 18L9 12L15 6\"\n                    stroke={colors.textWhite}\n                    strokeWidth={2.5}\n                    strokeLinecap=\"round\"\n                    strokeLinejoin=\"round\"\n                  />\n                </Svg>\n              </TouchableOpacity>\n            </View>\n\n            {/* Title */}\n            <Text style={[styles.heroTitle, isRTL && styles.heroTitleRTL]}>\n              {isRTL ? 'в•Әв”Ӯв”ҳГЁв•ӘВәв•Әв”Ӯв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ«в•Әв•Ўв”ҳГӘв•Әв•Ўв”ҳГЁв•ӘвҢҗ' : 'PRIVACY POLICY'}\n            </Text>\n\n            {/* Subtitle */}\n            <Text style={styles.heroSubtitle}>\n              {isRTL\n                ? 'в•ӘВәв”ҳГ©в•Әв–’в•ӘГә в•Әв”Ӯв”ҳГЁв•ӘВәв•Әв”Ӯв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ«в•Әв•Ўв”ҳГӘв•Әв•Ўв”ҳГЁв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ«в•ӘВәв•Әв•Ўв•ӘвҢҗ в•ӘВҝв”ҳГҘв•ӘВә'\n                : 'READ OUR PRIVACY POLICY'}\n            </Text>\n          </View>\n\n          {/* Content Card */}\n          <View style={styles.contentCard}>\n            <Text style={[styles.contentText, isRTL && styles.contentTextRTL]}>\n              {content ||\n                (isRTL ? 'в”ҳГӨв•ӘВә в•ӘВ¬в”ҳГӘв•ӘВјв•ӘВ» в•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в”ҳГ в•ӘВ¬в•ӘВәв•ӘВЎв•ӘвҢҗ' : 'No content available')}\n            </Text>\n          </View>\n        </ScrollView>\n      </View>\n    </View>\n  );\n};\n\nexport default Privacy;\n","usedDeprecatedRules":[{"ruleId":"no-negated-in-lhs","replacedBy":["no-unsafe-negation"]},{"ruleId":"no-catch-shadow","replacedBy":["no-shadow"]},{"ruleId":"handle-callback-err","replacedBy":[]},{"ruleId":"no-mixed-requires","replacedBy":[]},{"ruleId":"no-new-require","replacedBy":[]},{"ruleId":"no-path-concat","replacedBy":[]},{"ruleId":"no-restricted-modules","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"]}]},{"filePath":"C:\\Users\\mohse\\Desktop\\MasarraApp\\ClientSide\\src\\components\\Privacy\\index.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[{"ruleId":"no-negated-in-lhs","replacedBy":["no-unsafe-negation"]},{"ruleId":"no-catch-shadow","replacedBy":["no-shadow"]},{"ruleId":"handle-callback-err","replacedBy":[]},{"ruleId":"no-mixed-requires","replacedBy":[]},{"ruleId":"no-new-require","replacedBy":[]},{"ruleId":"no-path-concat","replacedBy":[]},{"ruleId":"no-restricted-modules","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"]}]},{"filePath":"C:\\Users\\mohse\\Desktop\\MasarraApp\\ClientSide\\src\\components\\Privacy\\styles.ts","mes