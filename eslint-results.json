nt}\n      </View>\n    );\n  },\n);\n","usedDeprecatedRules":[{"ruleId":"no-negated-in-lhs","replacedBy":["no-unsafe-negation"]},{"ruleId":"no-catch-shadow","replacedBy":["no-shadow"]},{"ruleId":"handle-callback-err","replacedBy":[]},{"ruleId":"no-mixed-requires","replacedBy":[]},{"ruleId":"no-new-require","replacedBy":[]},{"ruleId":"no-path-concat","replacedBy":[]},{"ruleId":"no-restricted-modules","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"]}]},{"filePath":"C:\\Users\\mohse\\Desktop\\MasarraApp\\ClientSide\\src\\components\\Auth\\ForgotPasswordModal.tsx","messages":[{"ruleId":"react-native/no-unused-styles","severity":1,"message":"Unused style detected: styles.passwordInputWrapper","line":830,"column":3,"nodeType":"Property","endLine":834,"endColumn":4}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState } from 'react';\nimport {\n  View,\n  Text,\n  TouchableOpacity,\n  TextInput,\n  Modal,\n  ActivityIndicator,\n  StyleSheet,\n} from 'react-native';\nimport Icon from 'react-native-vector-icons/Ionicons';\nimport { CustomAlert } from '../CustomAlert/CustomAlert';\nimport { colors } from '../../constants/colors';\nimport { useLanguage } from '../../contexts/LanguageContext';\nimport {\n  sendForgotPasswordCode,\n  resetPasswordWithCode,\n} from '../../utils/forgotPasswordUtils';\n\ninterface ForgotPasswordModalProps {\n  visible: boolean;\n  onClose: () => void;\n}\n\nconst ForgotPasswordModal: React.FC<ForgotPasswordModalProps> = ({\n  visible,\n  onClose,\n}) => {\n  const { isRTL } = useLanguage();\n  const [step, setStep] = useState<'email' | 'reset'>('email');\n  const [email, setEmail] = useState('');\n  const [resetCode, setResetCode] = useState('');\n  const [userId, setUserId] = useState<string>('');\n  const [newPassword, setNewPassword] = useState('');\n  const [confirmPassword, setConfirmPassword] = useState('');\n  const [isLoading, setIsLoading] = useState(false);\n  const [showNewPassword, setShowNewPassword] = useState(false);\n  const [showConfirmPassword, setShowConfirmPassword] = useState(false);\n  const [emailActive, setEmailActive] = useState(false);\n  const [codeActive, setCodeActive] = useState(false);\n  const [passwordActive, setPasswordActive] = useState(false);\n  const [confirmPasswordActive, setConfirmPasswordActive] = useState(false);\n  const [alertConfig, setAlertConfig] = useState({\n    visible: false,\n    title: '',\n    message: '',\n    buttons: [] as Array<{\n      text: string;\n      onPress?: () => void;\n      style?: 'default' | 'cancel' | 'destructive';\n    }>,\n  });\n\n  const showAlert = (\n    title: string,\n    message: string,\n    buttons: Array<{\n      text: string;\n      onPress?: () => void;\n      style?: 'default' | 'cancel' | 'destructive';\n    }> = [{ text: isRTL ? 'в•ӘВЎв•Әв”Ӯв”ҳГҘв•ӘВәв”ҳГҜ' : 'OK' }],\n  ) => {\n    setAlertConfig({ visible: true, title, message, buttons });\n  };\n\n  const hideAlert = () => {\n    setAlertConfig(prev => ({ ...prev, visible: false }));\n  };\n\n  const handleSendCode = async () => {\n    if (!email) {\n      showAlert(\n        isRTL ? 'в•ӘВ«в•Әв•–в•ӘГә' : 'Error',\n        isRTL ? 'в”ҳГЁв•Әв–’в•ӘВјв”ҳГ« в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВҝв•Әв–’в”ҳГЁв•ӘВ» в•ӘВәв”ҳГӨв•ӘГ‘в”ҳГӨв”ҳГўв•ӘВ¬в•Әв–’в”ҳГӘв”ҳГҘв”ҳГЁ' : 'Please enter your email',\n      );\n      return;\n    }\n\n    const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n    if (!emailRegex.test(email)) {\n      showAlert(\n        isRTL ? 'в•ӘВ«в•Әв•–в•ӘГә' : 'Error',\n        isRTL ? 'в”ҳГЁв•Әв–’в•ӘВјв”ҳГ« в•ӘГ‘в•ӘВ»в•ӘВ«в•ӘВәв”ҳГӨ в•ӘВҝв•Әв–’в”ҳГЁв•ӘВ» в•ӘГ‘в”ҳГӨв”ҳГўв•ӘВ¬в•Әв–’в”ҳГӘв”ҳГҘв”ҳГЁ в•Әв•Ўв•ӘВЎв”ҳГЁв•ӘВЎ' : 'Please enter a valid email',\n      );\n      return;\n    }\n\n    setIsLoading(true);\n    try {\n      const result = await sendForgotPasswordCode(email);\n\n      if (result.success && result.userId) {\n        setUserId(result.userId);\n        setStep('reset');\n        showAlert(\n          isRTL ? 'в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘГ‘в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ' : 'Code Sent',\n          isRTL\n            ? 'в•ӘВ¬в”ҳГ  в•ӘГ‘в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в”ҳГўв”ҳГӘв•ӘВ» в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ¬в•Әв•Јв”ҳГЁв”ҳГЁв”ҳГҘ в•ӘГ‘в”ҳГӨв”ҳГ« в•ӘВҝв•Әв–’в”ҳГЁв•ӘВ»в”ҳГў в•ӘВәв”ҳГӨв•ӘГ‘в”ҳГӨв”ҳГўв•ӘВ¬в•Әв–’в”ҳГӘв”ҳГҘв”ҳГЁ'\n            : 'Reset code has been sent to your email',\n        );\n      } else {\n        showAlert(\n          isRTL ? 'в•ӘВ«в•Әв•–в•ӘГә' : 'Error',\n          result.error || (isRTL ? 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘГ‘в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГўв”ҳГӘв•ӘВ»' : 'Failed to send code'),\n        );\n      }\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  const validatePassword = (\n    password: string,\n  ): { valid: boolean; message: string } => {\n    if (password.length < 8) {\n      return {\n        valid: false,\n        message: isRTL\n          ? 'в”ҳГЁв•ӘВјв•ӘВҝ в•ӘГәв”ҳГҘ в•ӘВ¬в”ҳГўв”ҳГӘв”ҳГҘ в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’ 8 в•ӘГәв•ӘВЎв•Әв–’в”ҳГј в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВәв”ҳГӨв•ӘГәв”ҳГ©в”ҳГӨ'\n          : 'Password must be at least 8 characters',\n      };\n    }\n    if (!/[A-Z]/.test(password)) {\n      return {\n        valid: false,\n        message: isRTL\n          ? 'в”ҳГЁв•ӘВјв•ӘВҝ в•ӘГәв”ҳГҘ в•ӘВ¬в•ӘВЎв•ӘВ¬в”ҳГӘв”ҳГЁ в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВЎв•Әв–’в”ҳГј в”ҳГўв•ӘВҝв”ҳГЁв•Әв–’ в”ҳГӘв•ӘВәв•ӘВЎв•ӘВ» в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВәв”ҳГӨв•ӘГәв”ҳГ©в”ҳГӨ'\n          : 'Password must contain at least one uppercase letter',\n      };\n    }\n    if (!/[a-z]/.test(password)) {\n      return {\n        valid: false,\n        message: isRTL\n          ? 'в”ҳГЁв•ӘВјв•ӘВҝ в•ӘГәв”ҳГҘ в•ӘВ¬в•ӘВЎв•ӘВ¬в”ҳГӘв”ҳГЁ в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВЎв•Әв–’в”ҳГј в•Әв•Ўв•Әв•‘в”ҳГЁв•Әв–’ в”ҳГӘв•ӘВәв•ӘВЎв•ӘВ» в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВәв”ҳГӨв•ӘГәв”ҳГ©в”ҳГӨ'\n          : 'Password must contain at least one lowercase letter',\n      };\n    }\n    if (!/[0-9]/.test(password)) {\n      return {\n        valid: false,\n        message: isRTL\n          ? 'в”ҳГЁв•ӘВјв•ӘВҝ в•ӘГәв”ҳГҘ в•ӘВ¬в•ӘВЎв•ӘВ¬в”ҳГӘв”ҳГЁ в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•Әв•Јв”ҳГӨв”ҳГ« в•Әв–’в”ҳГ©в”ҳГ  в”ҳГӘв•ӘВәв•ӘВЎв•ӘВ» в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВәв”ҳГӨв•ӘГәв”ҳГ©в”ҳГӨ'\n          : 'Password must contain at least one number',\n      };\n    }\n    return { valid: true, message: '' };\n  };\n\n  const handleResetPassword = async () => {\n    if (!resetCode || !newPassword || !confirmPassword) {\n      showAlert(\n        isRTL ? 'в•ӘВ«в•Әв•–в•ӘГә' : 'Error',\n        isRTL ? 'в•ӘВәв”ҳГӨв•Әв–’в•ӘВјв•ӘВәв•ӘГӯ в”ҳГ в”ҳГӨв•ӘГӯ в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВЎв”ҳГ©в”ҳГӘв”ҳГӨ' : 'Please fill all fields',\n      );\n      return;\n    }\n\n    const passwordValidation = validatePassword(newPassword);\n    if (!passwordValidation.valid) {\n      showAlert(isRTL ? 'в•ӘВ«в•Әв•–в•ӘГә' : 'Error', passwordValidation.message);\n      return;\n    }\n\n    if (newPassword !== confirmPassword) {\n      showAlert(\n        isRTL ? 'в•ӘВ«в•Әв•–в•ӘГә' : 'Error',\n        isRTL ? 'в”ҳГўв”ҳГӨв”ҳГ в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•Әв•‘в”ҳГЁв•Әв–’ в”ҳГ в•ӘВ¬в•Әв•–в•ӘВәв•ӘВҝв”ҳГ©в•ӘвҢҗ' : 'Passwords do not match',\n      );\n      return;\n    }\n\n    setIsLoading(true);\n    try {\n      const result = await resetPasswordWithCode(\n        userId,\n        resetCode,\n        newPassword,\n      );\n\n      if (result.success) {\n        showAlert(\n          isRTL ? 'в”ҳГҘв•ӘВјв•ӘВЎ' : 'Success',\n          isRTL\n            ? 'в•ӘВ¬в”ҳГ  в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВ¬в•Әв•Јв”ҳГЁв”ҳГЁв”ҳГҘ в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ'\n            : 'Password reset successfully',\n          [\n            {\n              text: isRTL ? 'в•ӘВЎв•Әв”Ӯв”ҳГҘв•ӘВәв”ҳГҜ' : 'OK',\n              onPress: handleClose,\n            },\n          ],\n        );\n      } else {\n        showAlert(\n          isRTL ? 'в•ӘВ«в•Әв•–в•ӘГә' : 'Error',\n          result.error ||\n            (isRTL\n              ? 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВ¬в•Әв•Јв”ҳГЁв”ҳГЁв”ҳГҘ в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’'\n              : 'Failed to reset password'),\n        );\n      }\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  const handleClose = () => {\n    setEmail('');\n    setResetCode('');\n    setUserId('');\n    setNewPassword('');\n    setConfirmPassword('');\n    setShowNewPassword(false);\n    setShowConfirmPassword(false);\n    setStep('email');\n    onClose();\n  };\n\n  return (\n    <Modal\n      visible={visible}\n      transparent={true}\n      animationType=\"fade\"\n      onRequestClose={handleClose}\n    >\n      <View style={styles.overlay}>\n        <View style={styles.modal}>\n          {/* Header */}\n          <View style={styles.header}>\n            <View style={styles.titleContainer}>\n              <Text style={[styles.title, isRTL && styles.titleRTL]}>\n                {isRTL ? 'в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВ¬в•Әв•Јв”ҳГЁв”ҳГЁв”ҳГҘ в”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’' : 'Reset Password'}\n              </Text>\n              <View\n                style={[\n                  styles.titleUnderline,\n                  isRTL && styles.titleUnderlineRTL,\n                ]}\n              />\n            </View>\n            <Text style={[styles.subtitle, isRTL && styles.subtitleRTL]}>\n              {step === 'email'\n                ? isRTL\n                  ? 'в•ӘГәв•ӘВ»в•ӘВ«в”ҳГӨ в•ӘВҝв•Әв–’в”ҳГЁв•ӘВ»в”ҳГў в•ӘВәв”ҳГӨв•ӘГ‘в”ҳГӨв”ҳГўв•ӘВ¬в•Әв–’в”ҳГӘв”ҳГҘв”ҳГЁ в”ҳГӨв•ӘВ¬в”ҳГӨв”ҳГ©в”ҳГЁ в•ӘВәв”ҳГӨв”ҳГўв”ҳГӘв•ӘВ»'\n                  : 'Enter your email to receive reset code'\n                : isRTL\n                ? 'в•ӘГәв•ӘВ»в•ӘВ«в”ҳГӨ в•ӘВәв”ҳГӨв”ҳГўв”ҳГӘв•ӘВ» в”ҳГӘв”ҳГўв”ҳГӨв”ҳГ в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в”ҳГӘв•Әв–’ в•ӘВәв”ҳГӨв•ӘВјв•ӘВ»в”ҳГЁв•ӘВ»в•ӘвҢҗ'\n                : 'Enter code and new password'}\n            </Text>\n          </View>\n\n          {/* Form */}\n          <View style={styles.form}>\n            {step === 'email' ? (\n              <>\n                <View style={styles.inputContainer}>\n                  <Text style={[styles.label, isRTL && styles.labelRTL]}>\n                    {isRTL ? 'в•ӘВәв”ҳГӨв•ӘВҝв•Әв–’в”ҳГЁв•ӘВ» в•ӘВәв”ҳГӨв•ӘГ‘в”ҳГӨв”ҳГўв•ӘВ¬в•Әв–’в”ҳГӘв”ҳГҘв”ҳГЁ' : 'Email'}\n                  </Text>\n                  <View\n                    style={[\n                      styles.sleekInputWrapper,\n                      isRTL && styles.sleekInputWrapperRTL,\n                      emailActive && styles.sleekInputWrapperActive,\n                    ]}\n                  >\n                    <Icon\n                      name=\"mail-outline\"\n                      size={18}\n                      color={emailActive ? colors.primary : '#9CA3AF'}\n                      style={[\n                        styles.sleekInputIcon,\n                        isRTL && styles.sleekInputIconRTL,\n                      ]}\n                    />\n                    <View\n                      style={[\n                        styles.sleekInputDivider,\n                        isRTL && styles.sleekInputDividerRTL,\n                      ]}\n                    />\n                    <TextInput\n                      style={[\n                        styles.sleekTextInput,\n                        isRTL && styles.sleekTextInputRTL,\n                      ]}\n                      value={email}\n                      onChangeText={setEmail}\n                      placeholder={\n                        isRTL ? 'в•ӘГәв•ӘВ»в•ӘВ«в”ҳГӨ в•ӘВҝв•Әв–’в”ҳГЁв•ӘВ»в”ҳГў в•ӘВәв”ҳГӨв•ӘГ‘в”ҳГӨв”ҳГўв•ӘВ¬в•Әв–’в”ҳГӘв”ҳГҘв”ҳГЁ' : 'Enter your email'\n                      }\n                      placeholderTextColor=\"#9CA3AF\"