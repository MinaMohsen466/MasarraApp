,\n  textAlign: \"isRTL ? 'right' : 'left'\"\n}","line":262,"column":40,"nodeType":"ObjectExpression","endLine":268,"endColumn":34},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  fontSize: 11,\n  color: '#64748B',\n  fontWeight: '500',\n  marginRight: 'isRTL ? 0 : 4',\n  marginLeft: 'isRTL ? 4 : 0'\n}","line":274,"column":42,"nodeType":"ObjectExpression","endLine":280,"endColumn":36},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  flexDirection: \"isRTL ? 'row-reverse' : 'row'\",\n  alignItems: 'center',\n  gap: 6,\n  marginBottom: 6\n}","line":288,"column":38,"nodeType":"ObjectExpression","endLine":293,"endColumn":32},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  fontSize: 11,\n  color: '#475569',\n  textAlign: \"isRTL ? 'right' : 'left'\",\n  flex: 1\n}","line":301,"column":40,"nodeType":"ObjectExpression","endLine":306,"endColumn":34},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  flexDirection: \"isRTL ? 'row-reverse' : 'row'\",\n  alignItems: 'center',\n  backgroundColor: 'isWithinWindow\\n' +\n    \"                                    ? '#ECFDF5'\\n\" +\n    \"                                    : '#FEF2F2'\",\n  paddingVertical: 6,\n  paddingHorizontal: 8,\n  borderRadius: 6,\n  gap: 6\n}","line":320,"column":40,"nodeType":"ObjectExpression","endLine":330,"endColumn":34},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  fontSize: 11,\n  fontWeight: '600',\n  color: 'isWithinWindow\\n' +\n    \"                                      ? '#047857'\\n\" +\n    \"                                      : '#B91C1C'\",\n  flex: 1,\n  textAlign: \"isRTL ? 'right' : 'left'\"\n}","line":342,"column":42,"nodeType":"ObjectExpression","endLine":350,"endColumn":36},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { flexDirection: \"isRTL ? 'row-reverse' : 'row'\"