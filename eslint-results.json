fix":{"range":[5954,5984],"text":"[getDaysInMonth]"}}]},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { flexDirection: 'row-reverse' }","line":344,"column":24,"nodeType":"ObjectExpression","endLine":344,"endColumn":56},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { flexDirection: 'row-reverse' }","line":370,"column":28,"nodeType":"ObjectExpression","endLine":370,"endColumn":60}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useEffect, useRef, useMemo } from 'react';\nimport {\n  View,\n  Text,\n  TouchableOpacity,\n  Modal,\n  ScrollView,\n  ActivityIndicator,\n  useWindowDimensions,\n} from 'react-native';\nimport Svg, { Path } from 'react-native-svg';\nimport { createStyles } from './styles';\nimport { colors } from '../../constants/colors';\nimport { useLanguage } from '../../contexts/LanguageContext';\nimport { checkBatchDateAvailability } from '../../services/api';\n\ninterface DatePickerModalProps {\n  visible: boolean;\n  onClose: () => void;\n  onSelectDate: (date: Date) => void;\n  serviceId: string;\n  vendorId: string;\n  selectedDate?: Date;\n  token?: string;\n}\n\n// Cache в”ҳГӨв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв”ҳГ в”ҳГӨв•ӘвҢҗ в•ӘВҝв•ӘВәв”ҳГӨв”ҳГјв•Әв•Јв”ҳГӨ\nconst availabilityCache = new Map<\n  string,\n  Map<string, { available: boolean; slots: number }>\n>();\n\n// в•ӘВ»в•ӘВәв”ҳГӨв•ӘвҢҗ в”ҳГӨв•ӘВЎв•Әв–‘в”ҳГј в•ӘВәв”ҳГӨв”ҳГҮ cache - в•ӘВ¬в”ҳГ…в•Әв”Ӯв•ӘВ¬в•ӘВ»в•Әв•Јв”ҳГ« в•ӘВҝв•Әв•Јв•ӘВ» в•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ» в•ӘВәв”ҳГӨв•ӘВЎв•ӘВјв•Әв–“\nexport const clearDatePickerCache = () => {\n  availabilityCache.clear();\n};\n\n// в•ӘВ»в•ӘВәв”ҳГӨв•ӘвҢҗ в”ҳГӨв•ӘВЎв•Әв–‘в”ҳГј cache в”ҳГӨв•ӘВ«в•ӘВ»в”ҳГ в•ӘвҢҗ в”ҳГ в•Әв•Јв”ҳГЁв”ҳГҘв•ӘвҢҗ\nexport const clearDatePickerCacheForService = (\n  serviceId: string,\n  vendorId: string,\n) => {\n  const keys = Array.from(availabilityCache.keys()).filter(key =>\n    key.startsWith(`${serviceId}-${vendorId}`),\n  );\n  keys.forEach(key => availabilityCache.delete(key));\n};\n\n// в•ӘВ»в•ӘВәв”ҳГӨв•ӘвҢҗ в”ҳГӨв•ӘВЎв•Әв–‘в”ҳГј cache в”ҳГӨв•Әв”Өв”ҳГ§в•Әв–’ в”ҳГ в•Әв•Јв”ҳГЁв”ҳГҘ в”ҳГ в”ҳГҘ в•ӘВ«в•ӘВ»в”ҳГ в•ӘвҢҗ в”ҳГ в•Әв•Јв”ҳГЁв”ҳГҘв•ӘвҢҗ (в•ӘВ¬в•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  в•Әв•Јв”ҳГҘв•ӘВ» в•ӘВәв”ҳГӨв•Әв–’в•ӘВјв”ҳГӘв•Әв•Ј в”ҳГӨв”ҳГҘв”ҳГјв•Әв”Ӯ в•ӘВәв”ҳГӨв•ӘВ«в•ӘВ»в”ҳГ в•ӘвҢҗ)\nexport const clearDatePickerCacheForMonth = (\n  serviceId: string,\n  vendorId: string,\n  year: number,\n  month: number,\n) => {\n  const cacheKey = `${serviceId}-${vendorId}-${year}-${month}`;\n  if (availabilityCache.has(cacheKey)) {\n    availabilityCache.delete(cacheKey);\n  }\n};\n\nconst DatePickerModal: React.FC<DatePickerModalProps> = ({\n  visible,\n  onClose,\n  onSelectDate,\n  serviceId,\n  vendorId,\n  selectedDate,\n  token,\n}) => {\n  const { width: SCREEN_WIDTH, height: SCREEN_HEIGHT } = useWindowDimensions();\n  const styles = createStyles(SCREEN_WIDTH, SCREEN_HEIGHT);\n  const { isRTL } = useLanguage();\n  const [currentMonth, setCurrentMonth] = useState(new Date());\n  const [availability, setAvailability] = useState<\n    Map<string, { available: boolean; slots: number }>\n  >(new Map());\n  const [loading, setLoading] = useState(false);\n  const loadingRef = useRef(false);\n\n  const monthNames = isRTL\n    ? [\n        'в”ҳГЁв”ҳГҘв•ӘВәв”ҳГЁв•Әв–’',\n        'в”ҳГјв•ӘВҝв•Әв–’в•ӘВәв”ҳГЁв•Әв–’',\n        'в”ҳГ в•ӘВәв•Әв–’в•Әв”Ӯ',\n        'в•ӘГәв•ӘВҝв•Әв–’в”ҳГЁв”ҳГӨ',\n        'в”ҳГ в•ӘВәв”ҳГЁв”ҳГӘ',\n        'в”ҳГЁв”ҳГӘв”ҳГҘв”ҳГЁв”ҳГӘ',\n        'в”ҳГЁв”ҳГӘв”ҳГӨв”ҳГЁв”ҳГӘ',\n        'в•ӘГәв•Әв•‘в•Әв”Ӯв•Әв•–в•Әв”Ӯ',\n        'в•Әв”Ӯв•ӘВҝв•ӘВ¬в”ҳГ в•ӘВҝв•Әв–’',\n        'в•ӘГәв”ҳГўв•ӘВ¬в”ҳГӘв•ӘВҝв•Әв–’',\n        'в”ҳГҘв”ҳГӘв”ҳГјв”ҳГ в•ӘВҝв•Әв–’',\n        'в•ӘВ»в”ҳГЁв•Әв”Ӯв”ҳГ в•ӘВҝв•Әв–’',\n      ]\n    : [\n        'January',\n        'February',\n        'March',\n        'April',\n        'May',\n        'June',\n        'July',\n        'August',\n        'September',\n        'October',\n        'November',\n        'December',\n      ];\n\n  const dayNamesBase = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];\n  const dayNamesBaseAr = [\n    'в•ӘГәв•ӘВЎв•ӘВ»',\n    'в•ӘГ‘в•ӘВҪв”ҳГҘв”ҳГЁв”ҳГҘ',\n    'в•ӘВҪв”ҳГӨв•ӘВәв•ӘВҪв•ӘВәв•ӘГӯ',\n    'в•ӘГәв•Әв–’в•ӘВҝв•Әв•Јв•ӘВәв•ӘГӯ',\n    'в•ӘВ«в”ҳГ в”ҳГЁв•Әв”Ӯ',\n    'в•ӘВјв”ҳГ в•Әв•Јв•ӘвҢҗ',\n    'в•Әв”Ӯв•ӘВҝв•ӘВ¬',\n  ];\n\n  // в”ҳГјв”ҳГЁ RTLв•ӘГ® в”ҳГҘв•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  flexDirection: 'row-reverse' в”ҳГӨв•ӘВ¬в•Әв•‘в”ҳГЁв”ҳГЁв•Әв–’ в•ӘВәв•ӘВ¬в•ӘВјв•ӘВәв”ҳГ§ в•ӘВәв”ҳГӨв•Әв•Јв•Әв–’в•Әв•ў в•ӘВ¬в”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГЁв•ӘВәв”ҳГҜ\n  const dayNames = isRTL ? dayNamesBaseAr : dayNamesBase;\n\n  // Memoize cache key в”ҳГӨв•ӘВ¬в•ӘВјв”ҳГҘв•ӘВҝ re-renders в•Әв•‘в”ҳГЁв•Әв–’ в•Әв•ўв•Әв–’в”ҳГӘв•Әв–’в”ҳГЁв•ӘвҢҗ\n  const cacheKey = useMemo(() => {\n    return `${serviceId}-${vendorId}-${currentMonth.getFullYear()}-${currentMonth.getMonth()}`;\n  }, [serviceId, vendorId, currentMonth]);\n\n  useEffect(() => {\n    if (visible) {\n      // в•ӘВ¬в•ӘВЎв”ҳГ©в”ҳГ© в”ҳГ в”ҳГҘ в•ӘВәв”ҳГӨв”ҳГҮ cache в•ӘГәв”ҳГӘв”ҳГӨв•ӘВәв”ҳГҜ\n      if (availabilityCache.has(cacheKey)) {\n        setAvailability(availabilityCache.get(cacheKey)!);\n        setLoading(false);\n      } else {\n        loadAvailability();\n      }\n    }\n  }, [visible, cacheKey]);\n\n  const loadAvailability = async () => {\n    if (loadingRef.current) return;\n\n    loadingRef.current = true;\n    setLoading(true);\n\n    try {\n      const availabilityMap = new Map();\n      const year = currentMonth.getFullYear();\n      const month = currentMonth.getMonth();\n      const daysInMonth = new Date(Date.UTC(year, month + 1, 0)).getUTCDate();\n      const today = new Date();\n      const todayUTC = new Date(\n        Date.UTC(today.getFullYear(), today.getMonth(), today.getDate()),\n      );\n\n      // в•ӘВЎв•ӘВ»в•ӘВ» в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв•ӘГәв”ҳГЁв•ӘВәв”ҳГ  в”ҳГӘв•ӘВәв”ҳГјв•Әв•Ўв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГ в•ӘВәв•Әв•ўв”ҳГЁв•ӘвҢҗ в•Әв•Јв”ҳГҘ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГ©в•ӘВҝв”ҳГӨв”ҳГЁв•ӘвҢҗ\n      const futureDates: Date[] = [];\n      for (let day = 1; day <= daysInMonth; day++) {\n        const date = new Date(Date.UTC(year, month, day));\n        if (date < todayUTC) {\n          const dateKey = `${date.getUTCFullYear()}-${(date.getUTCMonth() + 1)\n            .toString()\n            .padStart(2, '0')}-${date\n            .getUTCDate()\n            .toString()\n            .padStart(2, '0')}`;\n          availabilityMap.set(dateKey, { available: false, slots: 0 });\n        } else {\n          futureDates.push(date);\n        }\n      }\n\n      // в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  batch API в”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ в•ӘВјв”ҳГ в”ҳГЁв•Әв•Ј в•ӘВәв”ҳГӨв•ӘВ¬в”ҳГӘв•ӘВәв•Әв–’в”ҳГЁв•ӘВ« в•ӘВ»в”ҳГјв•Әв•Јв•ӘвҢҗ в”ҳГӘв•ӘВәв•ӘВЎв•ӘВ»в•ӘвҢҗ в•ӘВҝв•ӘВ»в”ҳГӨв•ӘВәв”ҳГҜ в”ҳГ в”ҳГҘ в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ»в•Әв•Јв•ӘВәв•ӘГӯв•ӘВәв•ӘВ¬ в”ҳГ в”ҳГҘв”ҳГјв•Әв•Ўв”ҳГӨв•ӘвҢҗ\n      const batchResults = await checkBatchDateAvailability(\n        serviceId,\n        vendorId,\n        futureDates,\n        token,\n      );\n\n      // в•ӘВ»в”ҳГ в•ӘВј в•ӘВәв”ҳГӨв”ҳГҘв•ӘВ¬в•ӘВәв•ӘВӘв•ӘВј\n      batchResults.forEach((value, key) => {\n        availabilityMap.set(key, value);\n      });\n\n      // в•ӘВЎв•ӘВ»в”ҳГҰв•ӘВҪ UI в”ҳГ в•Әв–’в•ӘвҢҗ в”ҳГӘв•ӘВәв•ӘВЎв•ӘВ»в•ӘвҢҗ в”ҳГјв”ҳГ©в•Әв•– в•ӘВҝв•Әв•Јв•ӘВ» в•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ в”ҳГўв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВҝв”ҳГЁв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬\n      setAvailability(new Map(availabilityMap));\n      availabilityCache.set(cacheKey, availabilityMap);\n    } finally {\n      setLoading(false);\n      loadingRef.current = false;\n    }\n  };\n\n  const getDaysInMonth = () => {\n    const year = currentMonth.getFullYear();\n    const month = currentMonth.getMonth();\n    // в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в”ҳГ  UTC dates в”ҳГӨв•ӘВ¬в•ӘВјв”ҳГҘв•ӘВҝ в”ҳГ в•Әв”Өв•ӘВәв”ҳГўв”ҳГӨ timezone\n    const firstDay = new Date(Date.UTC(year, month, 1));\n    const lastDay = new Date(Date.UTC(year, month + 1, 0));\n    const daysInMonth = lastDay.getUTCDate();\n    const startDayOfWeek = firstDay.getUTCDay();\n\n    const days: (Date | null)[] = [];\n\n    for (let i = 0; i < startDayOfWeek; i++) {\n      days.push(null);\n    }\n\n    for (let day = 1; day <= daysInMonth; day++) {\n      days.push(new Date(Date.UTC(year, month, day)));\n    }\n\n    return days;\n  };\n\n  // Memoize в•ӘГәв”ҳГЁв•ӘВәв”ҳГ  в•ӘВәв”ҳГӨв•Әв”Өв”ҳГ§в•Әв–’ в”ҳГӨв•ӘВ¬в•ӘВјв”ҳГҘв•ӘВҝ в•ӘГ‘в•Әв•Јв•ӘВәв•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ\n  const memoizedDays = useMemo(\n    () => getDaysInMonth(),\n    [currentMonth, getDaysInMonth],\n  );\n\n  const handlePrevMonth = () => {\n    setCurrentMonth(\n      new Date(currentMonth.getFullYear(), currentMonth.getMonth() - 1, 1),\n    );\n  };\n\n  const handleNextMonth = () => {\n    setCurrentMonth(\n      new Date(currentMonth.getFullYear(), currentMonth.getMonth() + 1, 1),\n    );\n  };\n\n  const handleSelectDate = (date: Date) => {\n    onSelectDate(date);\n    onClose();\n  };\n\n  const isDateSelected = (date: Date) => {\n    if (!selectedDate) return false;\n    return date.toDateString() === selectedDate.toDateString();\n  };\n  const getDateKey = (date: Date) =>\n    `${date.getUTCFullYear()}-${(date.getUTCMonth() + 1)\n      .toString()\n      .padStart(2, '0')}-${date.getUTCDate().toString().padStart(2, '0')}`;\n\n  const isPastDate = (date: Date) => {\n    const today = new Date();\n    const todayUTC = new Date(\n      Date.UTC(today.getFullYear(), today.getMonth(), today.getDate()),\n    );\n    return date < todayUTC;\n  };\n\n  const days = memoizedDays;\n\n  return (\n    <Modal\n      visible={visible}\n      transparent\n      animationType=\"fade\"\n      onRequestClose={onClose}\n    >\n      <TouchableOpacity\n        style={styles.modalOverlay}\n        activeOpacity={1}\n        onPress={onClose}\n      >\n        <TouchableOpacity\n          style={styles.modalContent}\n          activeOpacity={1}\n          onPress={e => e.stopPropagation()}\n        >\n          {/* Header */}\n          <View style={styles.header}>\n            <View style={styles.headerLeft}>\n              <Svg width={24} height={24} viewBox=\"0 0 24 24\" fill=\"none\">\n                <Path\n                  d=\"M8 2v4M16 2v4M3 10h18\"\n                  stroke={colors.primary}\n                  strokeWidth={1.8}\n                  strokeLinecap=\"round\"\n                  strokeLinejoin=\"round\"\n                />\n                <Path\n                  d=\"M19 4H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V6a2 2 0 00-2-2z\"\n                  stroke={colors.primary}\n                  strokeWidth={1.8}\n                  strokeLinecap=\"round\"\n                  strokeLinejoin=\"round\"\n                />\n              </Svg>\n              <Text style={styles.headerTitle}>\n                {isRTL ? 'в•ӘВәв•ӘВ«в•ӘВ¬в•Әв–’ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ«' : 'Select Date'}\n              </Text>\n            </View>\n          </View>\n\n          {/* Month Navigation */}\n          <View style={styles.monthNav}>\n            <TouchableOpacity\n              onPress={handlePrevMonth}\n              style={styles.navButton}\n            >\n              <Svg width={20} height={20} viewBox=\"0 0 24 24\" fill=\"none\">\n                <Path\n                  d=\"M15 18l-6-6 6-6\"\n                  stroke={colors.primary}\n                  strokeWidth={2}\n                  strokeLinecap=\"round\"\n                  strokeLinejoin=\"round\"\n                />\n              </Svg>\n            </TouchableOpacity>\n\n            <Text style={styles.monthTitle}>\n              {monthNames[currentMonth.getMonth()]} {currentMonth.getFullYear()}\n            </Text>\n\n            <TouchableOpacity\n              onPress={handleNextMonth}\n              style={styles.navButton}\n            >\n              <Svg width={20} height={20} viewBox=\"0 0 24 24\" fill=\"none\">\n                <Path\n                  d=\"M9 18l6-6-6-6\"\n                  stroke={colors.primary}\n                  strokeWidth={2}\n                  strokeLinecap=\"round\"\n                  strokeLinejoin=\"round\"\n                />\n              </Svg>\n            </TouchableOpacity>\n          </View>\n\n          {/* Day Names */}\n          <View\n            style={[\n              styles.dayNamesRow,\n              isRTL && { flexDirection: 'row-reverse' },\n            ]}\n          >\n            {dayNames.map((name, index) => (\n              <View key={index} style={styles.dayNameCell}>\n                <Text style={styles.dayNameText}>{name}</Text>\n              </View>\n            ))}\n          </View>\n\n          {/* Calendar Grid */}\n          <ScrollView\n            style={styles.calendarScroll}\n            showsVerticalScrollIndicator={false}\n          >\n            {loading ? (\n              <View style={styles.loadingContainer}>\n                <ActivityIndicator size=\"large\" color={colors.primary} />\n                <Text style={styles.loadingText}>\n                  {isRTL ? 'в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВЎв”ҳГ в”ҳГЁв”ҳГӨ...' : 'Loading...'}\n                </Text>\n              </View>\n            ) : (\n              <View\n                style={[\n                  styles.calendarGrid,\n                  isRTL && { flexDirection: 'row-reverse' },\n                ]}\n              >\n                {days.map((date, index) => {\n                  if (date === null) {\n                    return (\n                      <View key={`empty-${index}`} style={styles.dayCell} />\n                    );\n                  }\n\n                  const dateKey = getDateKey(date);\n                  const dateAvailability = availability.get(dateKey);\n                  const isPast = isPastDate(date);\n                  const isSelected = isDateSelected(date);\n                  const isFull =\n                    dateAvailability && !dateAvailability.available;\n\n                  return (\n                    <TouchableOpacity\n                      key={index}\n                      style={[\n                        styles.dayCell,\n                        isSelected && styles.dayCellSelected,\n                        isPast && styles.dayCellPast,\n                        isFull && styles.dayCellFull,\n                      ]}\n                      onPress={() => !isPast && handleSelectDate(date)}\n                      disabled={isPast}\n                      activeOpacity={0.7}\n                    >\n                      <Text\n                        style={[\n                          styles.dayText,\n                          isSelected && styles.dayTextSelected,\n                          isPast && styles.dayTextPast,\n                          isFull && styles.dayTextFull,\n                        ]}\n                      >\n                        {date.getDate()}\n                      </Text>\n\n                      {isFull && !isPast && (\n                        <Text style={styles.fullText}>\n                          {isRTL ? 'в”ҳГ в”ҳГ в•ӘВ¬в”ҳГӨв•ӘВӘ' : 'Full'}\n                        </Text>\n                      )}\n                    </TouchableOpacity>\n                  );\n                })}\n              </View>\n            )}\n          </ScrollView>\n\n          {/* Close Button */}\n          <TouchableOpacity style={styles.closeButton} onPress={onClose}>\n            <Text style={styles.closeButtonText}>\n              {isRTL ? 'в•ӘГ‘в•Әв•‘в”ҳГӨв•ӘВәв”ҳГ©' : 'Close'}\n            </Text>\n          </TouchableOpacity>\n        </TouchableOpacity>\n      </TouchableOpacity>\n    </Modal>\n  );\n};\n\nexport default DatePickerModal;\n","usedDeprecatedRules":[{"ruleId":"no-negated-in-lhs","replacedBy":["no-unsafe-negation"]},{"ruleId":"no-catch-shadow","replacedBy":["no-shadow"]},{"ruleId":"handle-callback-err","replacedBy":[]},{"ruleId":"no-mixed-requires","replacedBy":[]},{"ruleId":"no-new-require","replacedBy":[]},{"ruleId":"no-path-concat","replacedBy":[]},{"ruleId":"no-restricted-modules","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"]}]},{"filePath":"C:\\Users\\mohse\\Desktop\\MasarraApp\\ClientSide\\src\\components\\DatePickerModal\\styles.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[{"ruleId":"no-negated-in-lhs","replacedBy":["no-unsafe-negation"]},{"ruleId":"no-catch-shadow","replacedBy":["no-shadow"]},{"ruleId":"handle-callback-err","replacedBy":[]},{"ruleId":"no-mixed-requires","replacedBy":[]},{"ruleId":"no-new-require","replacedBy":[]},{"ruleId":"no-path-concat","replacedBy":[]},{"ruleId":"no-restricted-modules","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"]}]},{"filePath":"C:\\Users\\mohse\\Desktop\\MasarraApp\\ClientSide\\src\\components\\Drawer\\Drawer.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[{"ruleId":"no-negated-in-lhs","replacedBy":["no-unsafe-negation"]},{"ruleId":"no-catch-shadow","replacedBy":["no-shadow"]},{"ruleId":"handle-callback-err","replacedBy":[]},{"ruleId":"no-mixed-requires","replacedBy":[]},{"ruleId":"no-new-require","replacedBy":[]},{"ruleId":"no-path-concat","replacedBy":[]},{"ruleId":"no-restricted-modules","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"]}]},{"filePath":"C:\\Users\\mohse\\Desktop\\MasarraApp\\ClientSide\\src\\components\\Drawer\\index.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[{"ruleId":"no-negated-in-lhs","replacedBy":["no-unsafe-negati