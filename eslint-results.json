{"ruleId":"no-restricted-modules","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"]}]},{"filePath":"C:\\Users\\mohse\\Desktop\\MasarraApp\\ClientSide\\src\\components\\PaymentReceiptModal\\PaymentReceiptModal.tsx","messages":[{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { fontWeight: '700', color: '#111827' }","line":344,"column":23,"nodeType":"ObjectExpression","endLine":344,"endColumn":62},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { flex: 1 }","line":505,"column":61,"nodeType":"ObjectExpression","endLine":505,"endColumn":72}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from 'react';\nimport {\n  View,\n  Text,\n  TouchableOpacity,\n  Modal,\n  ScrollView,\n  Share,\n} from 'react-native';\nimport { SafeAreaView } from 'react-native-safe-area-context';\nimport Svg, { Circle, Path, Line } from 'react-native-svg';\nimport { colors } from '../../constants/colors';\nimport { useLanguage } from '../../contexts/LanguageContext';\nimport { styles } from './styles';\n\nexport interface ReceiptData {\n  status: 'success' | 'pending' | 'failed';\n  bookingId: string;\n  amount: number;\n  currency?: string;\n  paymentMethod?: string;\n  transactionId?: string;\n  invoiceId?: string;\n  referenceId?: string;\n  services: { name: string; quantity: number; total: number }[];\n  paidAt?: string | Date;\n  errorMessage?: string;\n}\n\ninterface PaymentReceiptModalProps {\n  visible: boolean;\n  receiptData: ReceiptData | null;\n  onClose: () => void;\n}\n\nconst PaymentReceiptModal: React.FC<PaymentReceiptModalProps> = ({\n  visible,\n  receiptData,\n  onClose,\n}) => {\n  const { isRTL } = useLanguage();\n\n  if (!receiptData) return null;\n\n  const {\n    status,\n    bookingId,\n    amount,\n    currency = 'KWD',\n    paymentMethod,\n    transactionId,\n    invoiceId,\n    referenceId,\n    services = [],\n    paidAt,\n    errorMessage,\n  } = receiptData;\n\n  const isSuccess = status === 'success';\n  const isPending = status === 'pending';\n\n  let formattedDate = '';\n  try {\n    const dateObj = paidAt ? new Date(paidAt) : new Date();\n    formattedDate = dateObj.toLocaleString(isRTL ? 'ar-KW' : 'en-KW', {\n      year: 'numeric',\n      month: 'long',\n      day: 'numeric',\n      hour: '2-digit',\n      minute: '2-digit',\n    });\n  } catch {\n    formattedDate = paidAt ? String(paidAt) : '';\n  }\n\n  const renderIcon = () => {\n    if (isSuccess) {\n      return (\n        <Svg width={56} height={56} viewBox=\"0 0 24 24\" fill=\"none\">\n          <Circle\n            cx=\"12\"\n            cy=\"12\"\n            r=\"10\"\n            stroke={colors.primary}\n            strokeWidth=\"2\"\n          />\n          <Path\n            d=\"M8 12l3 3 5-5\"\n            stroke={colors.primary}\n            strokeWidth=\"2\"\n            strokeLinecap=\"round\"\n            strokeLinejoin=\"round\"\n          />\n        </Svg>\n      );\n    }\n    if (isPending) {\n      return (\n        <Svg width={56} height={56} viewBox=\"0 0 24 24\" fill=\"none\">\n          <Circle cx=\"12\" cy=\"12\" r=\"10\" stroke=\"#f59e0b\" strokeWidth=\"2\" />\n          <Line\n            x1=\"12\"\n            y1=\"8\"\n            x2=\"12\"\n            y2=\"12\"\n            stroke=\"#f59e0b\"\n            strokeWidth=\"2\"\n            strokeLinecap=\"round\"\n          />\n          <Line\n            x1=\"12\"\n            y1=\"16\"\n            x2=\"12.01\"\n            y2=\"16\"\n            stroke=\"#f59e0b\"\n            strokeWidth=\"2\"\n            strokeLinecap=\"round\"\n          />\n        </Svg>\n      );\n    }\n    return (\n      <Svg width={56} height={56} viewBox=\"0 0 24 24\" fill=\"none\">\n        <Circle cx=\"12\" cy=\"12\" r=\"10\" stroke=\"#ef4444\" strokeWidth=\"2\" />\n        <Line\n          x1=\"15\"\n          y1=\"9\"\n          x2=\"9\"\n          y2=\"15\"\n          stroke=\"#ef4444\"\n          strokeWidth=\"2\"\n          strokeLinecap=\"round\"\n        />\n        <Line\n          x1=\"9\"\n          y1=\"9\"\n          x2=\"15\"\n          y2=\"15\"\n          stroke=\"#ef4444\"\n          strokeWidth=\"2\"\n          strokeLinecap=\"round\"\n        />\n      </Svg>\n    );\n  };\n\n  const getStatusText = () => {\n    if (isSuccess) return isRTL ? 'в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘВ»в”ҳГјв•Әв•Ј в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ' : 'Payment Successful';\n    if (isPending) return isRTL ? 'в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в”ҳГ в•Әв•Јв•ӘВәв”ҳГӨв•ӘВјв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ»в”ҳГјв•Әв•Ј' : 'Payment Processing';\n    return isRTL ? 'в”ҳГјв•Әв”Өв”ҳГӨ в•ӘВәв”ҳГӨв•ӘВ»в”ҳГјв•Әв•Ј' : 'Payment Failed';\n  };\n\n  const getTitle = () => {\n    if (isSuccess)\n      return isRTL ? 'в•Әв”Өв”ҳГўв•Әв–’в•ӘВәв”ҳГҜ в”ҳГӨв”ҳГў в•Әв•Јв”ҳГӨв”ҳГ« в•ӘВәв”ҳГӨв•ӘВ»в”ҳГјв•Әв•Ј!' : 'Thank you for your payment!';\n    if (isPending)\n      return isRTL ? 'в•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в”ҳГ в•Әв•Јв•ӘВәв”ҳГӨв•ӘВјв•ӘвҢҗ в•ӘВ»в”ҳГјв•Әв•Јв•ӘВ¬в”ҳГў' : 'Your payment is being processed';\n    return isRTL ? 'в”ҳГӨв”ҳГ  в”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•ӘВ»в”ҳГјв•Әв•Ј в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ' : 'Payment was not successful';\n  };\n\n  const getSubtitle = () => {\n    if (isSuccess)\n      return isRTL\n        ? 'в•ӘВ¬в”ҳГ  в•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ» в•ӘВЎв•ӘВјв•Әв–“в”ҳГў. в•ӘВ¬в”ҳГ  в•ӘГ‘в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в•ӘВҝв•Әв–’в”ҳГЁв•ӘВ» в•ӘГ‘в”ҳГӨв”ҳГўв•ӘВ¬в•Әв–’в”ҳГӘв”ҳГҘв”ҳГЁ в”ҳГӨв”ҳГӨв•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ».'\n        : 'Your booking has been confirmed. A confirmation email has been sent to you.';\n    if (isPending)\n      return isRTL\n        ? 'в”ҳГҘв•ӘВЎв”ҳГҘ в”ҳГҘв•ӘГұв”ҳГўв•ӘВ» в•ӘВ»в”ҳГјв•Әв•Јв•ӘВ¬в”ҳГў. в”ҳГЁв•Әв–’в•ӘВјв”ҳГ« в•ӘВәв”ҳГӨв•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ - в”ҳГ©в•ӘВ» в”ҳГЁв•Әв”Ӯв•ӘВ¬в•Әв•‘в•Әв–’в”ҳГ© в•Әв–‘в”ҳГӨв”ҳГў в•ӘВҝв•Әв•ўв•Әв•Ј в”ҳГӨв•ӘВЎв•Әв••в•ӘВәв•ӘВ¬. в•Әв”Ӯв”ҳГЁв•ӘВ¬в”ҳГ  в•ӘГ‘в•Әв•Јв”ҳГӨв•ӘВәв”ҳГ в”ҳГў в•ӘВҝв”ҳГ в•ӘВјв•Әв–’в•ӘВ» в•ӘВәв”ҳГӨв•ӘВ¬в•ӘГәв”ҳГўв”ҳГЁв•ӘВ».'\n        : 'We are confirming your payment. Please wait О“ГҮГ¶ this may take a few moments. You will be notified once confirmed.';\n    return (\n      errorMessage ||\n      (isRTL\n        ? 'в”ҳГӨв”ҳГ  в”ҳГҘв•ӘВ¬в”ҳГ в”ҳГўв”ҳГҘ в”ҳГ в”ҳГҘ в”ҳГ в•Әв•Јв•ӘВәв”ҳГӨв•ӘВјв•ӘвҢҗ в•ӘВ»в”ҳГјв•Әв•Јв•ӘВ¬в”ҳГў. в”ҳГӨв”ҳГ  в”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВ«в•Әв•Ўв”ҳГ  в•ӘГәв”ҳГЁ в”ҳГ в•ӘВҝв”ҳГӨв•Әв•‘. в”ҳГЁв•Әв–’в•ӘВјв”ҳГ« в•ӘВәв”ҳГӨв”ҳГ в•ӘВЎв•ӘВәв”ҳГӘв”ҳГӨв•ӘвҢҗ в”ҳГ в•Әв–’в•ӘвҢҗ в•ӘГәв•ӘВ«в•Әв–’в”ҳГ«.'\n        : 'Your payment could not be processed. No charge has been made. Please try again.')\n    );\n  };\n\n  const getAccentColor = () => {\n    if (isSuccess) return colors.primary;\n    if (isPending) return '#f59e0b'; // amber-500\n    return '#ef4444'; // red-500\n  };\n\n  const getBgColor = () => {\n    if (isSuccess) return 'rgba(0, 105, 92, 0.05)';\n    if (isPending) return 'rgba(245, 158, 11, 0.05)';\n    return 'rgba(239, 68, 68, 0.05)';\n  };\n\n  const handleShare = async () => {\n    try {\n      const servicesText = services\n        .map(\n          s => `- ${s.name} x${s.quantity}: ${s.total.toFixed(3)} ${currency}`,\n        )\n        .join('\\n');\n      const message = `${\n        isRTL ? 'в”ҳГјв•ӘВәв•ӘВ¬в”ҳГӘв•Әв–’в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ»в”ҳГјв•Әв•Ј в”ҳГ в”ҳГҘ в”ҳГ в•Әв”Ӯв•Әв–’в•ӘвҢҗ' : 'Payment Receipt from Masarra'\n      }\n      \n${isRTL ? 'в•ӘВЎв•ӘВәв”ҳГӨв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ»в”ҳГјв•Әв•Ј' : 'Status'}: ${getStatusText()}\n${isRTL ? 'в•Әв–’в”ҳГ©в”ҳГ  в•ӘВәв”ҳГӨв•ӘВЎв•ӘВјв•Әв–“' : 'Booking Reference'}: ${bookingId}\n${isRTL ? 'в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ« в”ҳГӘв•ӘВәв”ҳГӨв”ҳГӘв”ҳГ©в•ӘВ¬' : 'Date & Time'}: ${formattedDate}\n${\n  amount != null\n    ? `${isRTL ? 'в•ӘВәв”ҳГӨв”ҳГ в•ӘВҝв”ҳГӨв•Әв•‘ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ«в•Әв•Ўв”ҳГӘв”ҳГ ' : 'Amount Charged'}: ${amount.toFixed(\n        3,\n      )} ${currency}`\n    : ''\n}\n${\n  paymentMethod\n    ? `${isRTL ? 'в•Әв•–в•Әв–’в”ҳГЁв”ҳГ©в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ»в”ҳГјв•Әв•Ј' : 'Payment Method'}: ${paymentMethod}`\n    : ''\n}\n${invoiceId ? `${isRTL ? 'в•Әв–’в”ҳГ©в”ҳГ  в•ӘВәв”ҳГӨв”ҳГјв•ӘВәв•ӘВ¬в”ҳГӘв•Әв–’в•ӘвҢҗ' : 'Invoice ID'}: ${invoiceId}` : ''}\n${\n  transactionId\n    ? `${isRTL ? 'в•Әв–’в”ҳГ©в”ҳГ  в•ӘВәв”ҳГӨв”ҳГ в•Әв•Јв•ӘВәв”ҳГ в”ҳГӨв•ӘвҢҗ' : 'Transaction ID'}: ${transactionId}`\n    : ''\n}\n${\n  referenceId\n    ? `${isRTL ? 'в•ӘВәв”ҳГӨв•Әв–’в”ҳГ©в”ҳГ  в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в•ӘВјв•Әв•Јв”ҳГЁ' : 'Reference ID'}: ${referenceId}`\n    : ''\n}\n\n${isRTL ? 'в•ӘВәв”ҳГӨв•ӘВ«в•ӘВ»в”ҳГ в•ӘВәв•ӘВ¬' : 'Services'}:\n${servicesText}\n\n${\n  amount != null\n    ? `${isRTL ? 'в•ӘВәв”ҳГӨв”ҳГ в•ӘВјв”ҳГ в”ҳГӘв•Әв•Ј' : 'Total'}: ${amount.toFixed(3)} ${currency}`\n    : ''\n}`;\n\n      await Share.share({\n        message,\n        title: isRTL ? 'в”ҳГјв•ӘВәв•ӘВ¬в”ҳГӘв•Әв–’в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ»в”ҳГјв•Әв•Ј' : 'Payment Receipt',\n      });\n    } catch (error) {\n      console.error('Error sharing receipt:', error);\n    }\n  };\n\n  return (\n    <Modal\n      visible={visible}\n      animationType=\"slide\"\n      transparent={true}\n      onRequestClose={onClose}\n    >\n      <SafeAreaView style={styles.modalOverlay}>\n        <View style={styles.modalContainer}>\n          {/* Header Strip */}\n          <View\n            style={[styles.headerStrip, { backgroundColor: getAccentColor() }]}\n          />\n\n          <ScrollView\n            showsVerticalScrollIndicator={false}\n            contentContainerStyle={styles.scrollContent}\n          >\n            {/* Status Section */}\n            <View style={styles.statusSection}>\n              <View\n                style={[\n                  styles.iconRing,\n                  { backgroundColor: getBgColor(), borderColor: getBgColor() },\n                ]}\n              >\n                {renderIcon()}\n              </View>\n\n              <View\n                style={[\n                  styles.badge,\n                  { backgroundColor: getBgColor(), borderColor: getBgColor() },\n                ]}\n              >\n                <Text style={[styles.badgeText, { color: getAccentColor() }]}>\n                  {getStatusText()}\n                </Text>\n              </View>\n\n              <Text style={styles.title}>{getTitle()}</Text>\n              <Text style={styles.subtitle}>{getSubtitle()}</Text>\n            </View>\n\n            {/* Divider */}\n            <View style={styles.dividerContainer}>\n              <View style={styles.dividerLine} />\n              <Text style={styles.dividerText}>\n                {isRTL ? 'в•ӘВәв”ҳГӨв”ҳГјв•ӘВәв•ӘВ¬в”ҳГӘв•Әв–’в•ӘвҢҗ' : 'RECEIPT'}\n              </Text>\n              <View style={styles.dividerLine} />\n            </View>\n\n            {/* Details Section */}\n            <View style={styles.detailsSection}>\n              {/* Booking Reference */}\n              <View style={[styles.detailRow, isRTL && styles.detailRowRTL]}>\n                <Text\n                  style={[styles.detailLabel, isRTL && styles.detailLabelRTL]}\n                >\n                  {isRTL ? 'в•Әв–’в”ҳГ©в”ҳГ  в•ӘВәв”ҳГӨв•ӘВЎв•ӘВјв•Әв–“' : 'Booking Reference'}\n                </Text>\n                <Text\n                  style={[\n                    styles.detailValueMono,\n                    isRTL && styles.detailValueMonoRTL,\n                  ]}\n                >\n                  {bookingId}\n                </Text>\n              </View>\n\n              {/* Date & Time */}\n              <View style={[styles.detailRow, isRTL && styles.detailRowRTL]}>\n                <Text\n                  style={[styles.detailLabel, isRTL && styles.detailLabelRTL]}\n                >\n                  {isRTL ? 'в•ӘВәв”ҳГӨв•ӘВ¬в•ӘВәв•Әв–’в”ҳГЁв•ӘВ« в”ҳГӘв•ӘВәв”ҳГӨв”ҳГӘв”ҳГ©в•ӘВ¬' : 'Date & Time'}\n                </Text>\n                <Text\n                  style={[styles.detailValue, isRTL && styles.detailValueRTL]}\n                >\n                  {formattedDate}\n                </Text>\n              </View>\n\n              {/* Amount Charged */}\n              {amount != null && (\n                <View style={[styles.detailRow, isRTL && styles.detailRowRTL]}>\n                  <Text\n                    style={[styles.detailLabel, isRTL && styles.detailLabelRTL]}\n                  >\n                    {isRTL ? 'в•ӘВәв”ҳГӨв”ҳГ в•ӘВҝв”ҳГӨв•Әв•‘ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ«в•Әв•Ўв”ҳГӘв”ҳГ ' : 'Amount Charged'}\n                  </Text>\n                  <Text\n                    style={[\n                      styles.detailValue,\n                      isRTL && styles.detailValueRTL,\n                      { fontWeight: '700', color: '#111827' },\n                    ]}\n                  >\n                    {amount.toFixed(3)} {currency}\n                  </Text>\n                </View>\n              )}\n\n              {/* Payment Method */}\n              {paymentMethod && (\n                <View style={[styles.detailRow, isRTL && styles.detailRowRTL]}>\n                  <Text\n                    style={[styles.detailLabel, isRTL && styles.detailLabelRTL]}\n                  >\n                    {isRTL ? 'в•Әв•–в•Әв–’в”ҳГЁв”ҳГ©в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ»в”ҳГјв•Әв•Ј' : 'Payment Method'}\n                  </Text>\n                  <Text\n                    style={[styles.detailValue, isRTL && styles.detailValueRTL]}\n                  >\n                    {paymentMethod}\n                  </Text>\n                </View>\n              )}\n\n              {/* Invoice ID */}\n              {invoiceId && (\n                <View style={[styles.detailRow, isRTL && styles.detailRowRTL]}>\n                  <Text\n                    style={[styles.detailLabel, isRTL && styles.detailLabelRTL]}\n                  >\n                    {isRTL ? 'в•Әв–’в”ҳГ©в”ҳГ  в•ӘВәв”ҳГӨв”ҳГјв•ӘВәв•ӘВ¬в”ҳГӘв•Әв–’в•ӘвҢҗ' : 'Invoice ID'}\n                  </Text>\n                  <Text\n                    style={[\n                      styles.detailValueMono,\n                      isRTL && styles.detailValueMonoRTL,\n                    ]}\n                  >\n                    {invoiceId}\n                  </Text>\n                </View>\n              )}\n\n              {/* Transaction ID */}\n              {transactionId && (\n                <View style={[styles.detailRow, isRTL && styles.detailRowRTL]}>\n                  <Text\n                    style={[styles.detailLabel, isRTL && styles.detailLabelRTL]}\n                  >\n                    {isRTL ? 'в•Әв–’в”ҳГ©в”ҳГ  в•ӘВәв”ҳГӨв”ҳГ в•Әв•Јв•ӘВәв”ҳГ в”ҳГӨв•ӘвҢҗ' : 'Transaction ID'}\n                  </Text>\n                  <Text\n                    style={[\n                      styles.detailValueMono,\n                      isRTL && styles.detailValueMonoRTL,\n                    ]}\n                  >\n                    {transactionId}\n                  </Text>\n                </View>\n              )}\n\n              {/* Reference ID */}\n              {referenceId && (\n                <View style={[styles.detailRow, isRTL && styles.detailRowRTL]}>\n                  <Text\n                    style={[styles.detailLabel, isRTL && styles.detailLabelRTL]}\n                  >\n                    {isRTL ? 'в•ӘВәв”ҳГӨв•Әв–’в”ҳГ©в”ҳГ  в•ӘВәв”ҳГӨв”ҳГ в•Әв–’в•ӘВјв•Әв•Јв”ҳГЁ' : 'Reference ID'}\n                  </Text>\n                  <Text\n                    style={[\n                      styles.detailValueMono,\n                      isRTL && styles.detailValueMonoRTL,\n                    ]}\n                  >\n                    {referenceId}\n                  </Text>\n                </View>\n              )}\n\n              {/* Services List */}\n              {services.length > 0 && (\n                <View style={styles.servicesContainer}>\n                  <Text\n                    style={[\n                      styles.servicesTitle,\n                      isRTL && styles.servicesTitleRTL,\n                    ]}\n                  >\n                    {isRTL ? 'в•ӘВәв”ҳГӨв•ӘВ«в•ӘВ»в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӨв”ҳГ в•ӘВ»в”ҳГјв”ҳГӘв•Әв•Јв•ӘвҢҗ' : 'SERVICES PAID'}\n                  </Text>\n                  {services.map((svc, idx) => (\n                    <View\n                      key={idx}\n                      style={[styles.serviceRow, isRTL && styles.serviceRowRTL]}\n                    >\n                      <Text\n                        style={[\n                          styles.serviceName,\n                          isRTL && styles.serviceNameRTL,\n                        ]}\n                        numberOfLines={1}\n                      >\n                        {svc.name || (isRTL ? 'в•ӘВ«в•ӘВ»в”ҳГ в•ӘвҢҗ' : 'Service')}\n                        {svc.quantity > 1 && ` в”ңГ№ ${svc.quantity}`}\n                      </Text>\n                      <Text\n                        style={[\n                          styles.serviceTotal,\n                          isRTL && styles.serviceTotalRTL,\n                        ]}\n                      >\n                        {svc.total.toFixed(3)} {currency}\n                      </Text>\n                    </View>\n                  ))}\n                </View>\n              )}\n\n              {/* Total Row */}\n              {amount != null && (\n                <View style={[styles.totalRow, isRTL && styles.totalRowRTL]}>\n                  <Text\n                    style={[styles.totalLabel, isRTL && styles.totalLabelRTL]}\n                  >\n                    {isRTL ? 'в•ӘВәв”ҳГӨв”ҳГ в•ӘВјв”ҳГ в”ҳГӘв•Әв•Ј' : 'Total'}\n                  </Text>\n                  <Text\n                    style={[styles.totalValue, isRTL && styles.totalValueRTL]}\n                  >\n                    {amount.toFixed(3)} {currency}\n                  </Text>\n                </View>\n              )}\n            </View>\n\n            {/* Actions */}\n            <View style={styles.actionsContainer}>\n              <View style={styles.actionsRow}>\n                {isSuccess && (\n                  <TouchableOpacity\n                    style={styles.shareButton}\n                    onPress={handleShare}\n                  >\n                    <Svg width={20} height={20} viewBox=\"0 0 24 24\" fill=\"none\">\n                      <Path\n                        d=\"M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8M16 6l-4-4-4 4M12 2v13\"\n                        stroke={colors.primary}\n                        strokeWidth=\"2\"\n                        strokeLinecap=\"round\"\n                        strokeLinejoin=\"round\"\n                      />\n                    </Svg>\n                    <Text style={styles.shareButtonText}>\n                      {isRTL ? 'в”ҳГ в•Әв”Өв•ӘВәв•Әв–’в”ҳГўв•ӘвҢҗ / в•Әв•–в•ӘВҝв•ӘВәв•Әв•Јв•ӘвҢҗ' : 'Share / Print'}\n                    </Text>\n                  </TouchableOpacity>\n                )}\n\n                <TouchableOpacity\n                  style={[styles.closeButton, !isSuccess && { flex: 1 }]}\n                  onPress={onClose}\n                >\n                  <Text style={styles.closeButtonText}>\n                    {isRTL ? 'в•ӘГ‘в•Әв•‘в”ҳГӨв•ӘВәв”ҳГ©' : 'Close'}\n                  </Text>\n                </TouchableOpacity>\n              </View>\n            </View>\n\n            <View style={styles.footer}>\n              <Text style={styles.footerText}>\n                {isRTL\n                  ? 'в”ҳГ§в•Әв–‘в”ҳГ§ в•ӘВәв”ҳГӨв”ҳГјв•ӘВәв•ӘВ¬в”ҳГӘв•Әв–’в•ӘвҢҗ в•ӘВ¬в”ҳГ  в•ӘГ‘в”ҳГҘв•Әв”Өв•ӘВәв•ӘГұв”ҳГ§в•ӘВә в•ӘВ¬в”ҳГӨв”ҳГ©в•ӘВәв•ӘВӘв”ҳГЁв•ӘВәв”ҳГҜ. в”ҳГ в•Әв•Јв•ӘВәв”ҳГӨв•ӘВјв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘВ»в”ҳГјв•Әв•Ј в•ӘВәв”ҳГӨв•ӘГів”ҳГ в”ҳГҘв•ӘвҢҗ в•ӘВ¬в•ӘВ¬в”ҳГ  в•ӘВҝв”ҳГӘв•ӘВәв•Әв”Ӯв•Әв•–в•ӘвҢҗ MyFatoorah.'\n                  : 'This receipt is auto-generated. Secure payment processed by MyFatoorah.'}\n              </Text>\n            </View>\n          </ScrollView>\n        </View>\n      </SafeAreaV