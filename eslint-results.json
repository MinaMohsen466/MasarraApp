ty":1,"message":"Inline style: { flex: 1 }","line":771,"column":14,"nodeType":"ObjectExpression","endLine":771,"endColumn":61},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { flexGrow: 1 }","line":772,"column":30,"nodeType":"ObjectExpression","endLine":772,"endColumn":45},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { paddingTop: 'insets.top > 24 ? insets.top - 12 : 8' }","line":821,"column":13,"nodeType":"ObjectExpression","endLine":821,"endColumn":66},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  flexDirection: \"isRTL ? 'row-reverse' : 'row'\",\n  alignItems: 'center',\n  backgroundColor: 'rgba(255, 255, 255, 0.18)',\n  paddingHorizontal: 12,\n  paddingVertical: 6,\n  borderRadius: 20,\n  height: 36\n}","line":841,"column":20,"nodeType":"ObjectExpression","endLine":849,"endColumn":14},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { marginRight: 'isRTL ? 0 : 6', marginLeft: 'isRTL ? 6 : 0' }","line":857,"column":22,"nodeType":"ObjectExpression","endLine":857,"endColumn":79},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { fontSize: 13, fontWeight: '600', fontFamily: 'System' }","line":860,"column":22,"nodeType":"ObjectExpression","endLine":865,"endColumn":16},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { marginBottom: 20 }","line":909,"column":58,"nodeType":"ObjectExpression","endLine":909,"endColumn":78},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { marginBottom: 16, fontSize: 13 }","line":931,"column":13,"nodeType":"ObjectExpression","endLine":931,"endColumn":76},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  fontSize: 14,\n  marginBottom: 24,\n  textAlign: \"isRTL ? 'right' : 'left'\"\n}","line":943,"column":13,"nodeType":"ObjectExpression","endLine":948,"endColumn":14},{"ruleId":"