isBold ? 'Tajawal-Bold' : 'Tajawal-Regular' },\n    ];\n    return <OriginalTextInput {...props} style={newStyle} ref={ref} />;\n  }\n  return <OriginalTextInput {...props} ref={ref} />;\n});\n\n// Copy static properties of TextInput\nObject.keys(OriginalTextInput).forEach(key => {\n  WrappedTextInput[key] = OriginalTextInput[key];\n});\n\nObject.defineProperty(reactNative, 'TextInput', {\n  get() {\n    return WrappedTextInput;\n  },\n  configurable: true,\n  enumerable: true,\n});\n\nAppRegistry.registerComponent(appName, () => App);\n","usedDeprecatedRules":[{"ruleId":"no-negated-in-lhs","replacedBy":["no-unsafe-negation"]},{"ruleId":"no-catch-shadow","replacedBy":["no-shadow"]},{"ruleId":"handle-callback-err","replacedBy":[]},{"ruleId":"no-mixed-requires","replacedBy":[]},{"ruleId":"no-new-require","replacedBy":[]},{"ruleId":"no-path-concat","replacedBy":[]},{"ruleId":"no-restricted-modules","replacedBy":[]},{"ruleId":"no-new-object","replacedBy":["no-object-constructor"]}]},{"filePath":"C:\\Users\\mohse\\Desktop\\MasarraApp\\ClientSide\\scripts\\pre-commit-check.js","messages":[{"ruleId":"no-console","severity":1,"message":"Unexpected console statement.","line":18,"column":3,"nodeType":"MemberExpression","messageId":"unexpected","endLine":18,"endColumn":14,"suggestions":[{"messageId":"removeConsole","data":{"propertyName":"log"},"fix":{"range":[344,393],"text":""},"desc":"Remove the console.log()."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'error' is defined but never used.","line":27,"column":12,"nodeType":null,"messageId":"unusedVar","endLine":27,"endColumn":17}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"#!/usr/bin/env node\r\n/**\r\n * Pre-commit validation script\r\n * Runs linting, formatting, and type checking\r\n */\r\n\r\nconst { execSync } = require('child_process');\r\n\r\nconst colors = {\r\n  reset: '\\x1b[0m',\r\n  green: '\\x1b[32m',\r\n  red: '\\x1b[31m',\r\n  yellow: '\\x1b[33m',\r\n  cyan: '\\x1b[36m',\r\n};\r\n\r\nfunction log(message, color = colors.reset) {\r\n  console.log(`${color}${message}${colors.reset}`);\r\n}\r\n\r\nfunction runCommand(command, description) {\r\n  log(`\\nвүЎЖ’Г¶Г¬ ${description}...`, colors.cyan);\r\n  try {\r\n    execSync(command, { stdio: 'inherit' });\r\n    log(`О“ВЈГ  ${description} passed!`, colors.green);\r\n    return true;\r\n  } catch (error) {\r\n    log(`О“ВҘГ® ${description} failed!`, colors.red);\r\n    return false;\r\n  }\r\n}\r\n\r\nasync function main() {\r\n  log('\\nвүЎЖ’ГңГҮ Running pre-commit checks...\\n', colors.yellow);\r\n\r\n  const checks = [\r\n    {\r\n      command: 'npm run type-check',\r\n      description: 'TypeScript type checking',\r\n    },\r\n    {\r\n      command: 'npm run lint',\r\n      description: 'ESLint validation',\r\n    },\r\n    {\r\n      command: 'npm run format:check',\r\n      description: 'Prettier format checking',\r\n    },\r\n  ];\r\n\r\n  let allPassed = true;\r\n\r\n  for (const check of checks) {\r\n    const passed = runCommand(check.command, check.description);\r\n    if (!passed) {\r\n      allPassed = false;\r\n    }\r\n  }\r\n\r\n  if (allPassed) {\r\n    log('\\nО“ВЈГ  All checks passed! Ready to commit.\\n', colors.green);\r\n    process.exit(0);\r\n  } else {\r\n    log('\\nО“ВҘГ® Some checks failed. Please fix the issues before committing.\\n', colors.red);\r\n    log('вүЎЖ’ГҶГӯ Tip: Run \"npm run lint:fix\" to auto-fix some issues.\\n', colors.yellow);\r\n    process.exit(1);\r\n  }\r\n}\r\n\r\nmain().catch((error) => {\r\n  log(`\\nО“ВҘГ® Error: ${error.message}\\n`, colors.red);\r\n  process.exit(1);\r\n});\r\n","usedDeprecatedRules":[{"ruleId":"no-negated-in-lhs","replacedBy":["no-unsafe-negation"]},{"ruleId":"no-catch-shadow","replacedBy":["no-shadow"]},{"ruleId":"handle-callback-err","replacedBy":[]},{"ruleId":"no-mixed-requires","replacedBy":[]},{"ruleId":"no-new-require","replacedB