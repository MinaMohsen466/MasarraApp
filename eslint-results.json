   ? 0.6\\n' +\n    '                          : 1',\n  justifyContent: 'center',\n  alignItems: 'center',\n  minWidth: 120\n}","line":443,"column":28,"nodeType":"ObjectExpression","endLine":455,"endColumn":22},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { fontSize: 14, fontWeight: '600', color: '#fff' }","line":461,"column":32,"nodeType":"ObjectExpression","endLine":465,"endColumn":26},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { alignItems: 'center', width: '100%' }","line":474,"column":28,"nodeType":"ObjectExpression","endLine":474,"endColumn":67},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  flexDirection: \"isRTL ? 'row-reverse' : 'row'\",\n  alignItems: 'center',\n  backgroundColor: '#FEF2F2',\n  borderWidth: 1,\n  borderColor: '#FEE2E2',\n  borderLeftWidth: 'isRTL ? 1 : 4',\n  borderRightWidth: 'isRTL ? 4 : 1',\n  borderLeftColor: \"isRTL ? '#FEE2E2' : '#EF4444'\",\n  borderRightColor: \"isRTL ? '#EF4444' : '#FEE2E2'\",\n  borderRadius: 10,\n  padding: 16,\n  width: '100%',\n  marginBottom: 20,\n  gap: 8\n}","line":477,"column":26,"nodeType":"ObjectExpression","endLine":492,"endColumn":20},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  color: '#991B1B',\n  fontSize: 14,\n  fontWeight: '600',\n  flex: 1,\n  textAlign: \"isRTL ? 'right' : 'left'\"\n}","line":496,"column":28,"nodeType":"ObjectExpression","endLine":502,"endColumn":22},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  paddingVertical: 10,\n  paddingHorizontal: 24,\n  borderRadius: 10,\n  shadowOpacity: 0.15,\n  shadowRadius: 4,\n  elevation: 2\n}","line":510,"column":26,"nodeType":"ObjectExpression","endLine":520,"endColumn":20},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { fontSize: 14, fontWeight: '600', color: '#fff' }","line":523,"column":28,"nodeType":"ObjectExpression","endLine":527,"endColumn":22},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { alignItems: 'center', width: '100%' }","line":534,"column":28,"nodeType":"ObjectExpression","endLine":534,"endColumn":67},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  flexDirection: \"isRTL ? 'row-reverse' : 'row'\",\n  alignItems: 'center',\n  backgroundColor: '#F0FDF4',\n  borderWidth: 1,\n  borderColor: '#DCFCE7',\n  borderLeftWidth: 'isRTL ? 1 : 4',\n  borderRightWidth: 'isRTL ? 4 : 1',\n  borderLeftColor: \"isRTL ? '#DCFCE7' : '#22C55E'\",\n  borderRightColor: \"isRTL ? '#22C55E' : '#DCFCE7'\",\n  borderRadius: 10,\n  padding: 16,\n  width: '100%',\n  marginBottom: 16,\n  gap: 8\n}","line":537,"column":26,"nodeType":"ObjectExpression","endLine":552,"endColumn":20},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  color: '#166534',\n  fontSize: 14,\n  fontWeight: '600',\n  flex: 1,\n  textAlign: \"isRTL ? 'right' : 'left'\",\n  lineHeight: 20\n}","line":560,"column":28,"nodeType":"ObjectExpression","endLine":567,"endColumn":22},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  backgroundColor: '#FEF2F2',\n  borderWidth: 1,\n  borderColor: '#FEE2E2',\n  borderLeftWidth: 'isRTL ? 1 : 4',\n  borderRightWidth: 'isRTL ? 4 : 1',\n  borderLeftColor: \"isRTL ? '#FEE2E2' : '#EF4444'\",\n  borderRightColor: \"isRTL ? '#EF4444' : '#FEE2E2'\",\n  borderRadius: 10,\n  padding: 12,\n  width: '100%',\n  marginBottom: 20,\n  flexDirection: \"isRTL ? 'row-reverse' : 'row'\",\n  alignItems: 'flex-start',\n  gap: 8\n}","line":579,"column":28,"nodeType":"ObjectExpression","endLine":594,"endColumn":22},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  marginTop: 2,\n  marginRight: 'isRTL ? 0 : 2',\n  marginLeft: 'isRTL ? 2 : 0'\n}","line":600,"column":30,"nodeType":"ObjectExpression","endLine":604,"endColumn":24},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  color: '#991B1B',\n  fontSize: 12,\n  lineHeight: 18,\n  flex: 1,\n  fontWeight: '500',\n  textAlign: \"isRTL ? 'right' : 'left'\"\n}","line":607,"column":30,"nodeType":"ObjectExpression","endLine":614,"endColumn":24},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  color: '#64748B',\n  fontSize: 12,\n  textAlign: 'center',\n  marginBottom: 20,\n  lineHeight: 16\n}","line":623,"column":28,"nodeType":"ObjectExpression","endLine":629,"endColumn":22},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: {\n  paddingVertical: 10,\n  paddingHorizontal: 24,\n  borderRadius: 10,\n  shadowOpacity: 0.15,\n  shadowRadius: 4,\n  elevation: 2\n}","line":639,"column":26,"nodeType":"ObjectExpression","endLine":649,"endColumn":20},{"ruleId":"react-native/no-inline-styles","severity":1,"message":"Inline style: { fontSize: 14, fontWeight: '600', color: '#fff' }","line":652,"column":28,"nodeType":"ObjectExpression","endLine":656,"endColumn":22}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":44,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from 'react';\nimport {\n  View,\n  Text,\n  ScrollView,\n  TouchableOpacity,\n  TextInput,\n  ActivityIndicator,\n  Modal,\n} from 'react-native';\nimport Icon from 'react-native-vector-icons/Ionicons';\nimport { colors } from '../../constants/colors';\nimport { Booking } from '../../services/bookingApi'; // We can import from bookingApi/apiFacade since they are re-exported.\n\ninterface CancellationRequestModalProps {\n  visible: boolean;\n  isRTL: boolean;\n  selectedCancellationBooking: Booking | null;\n  cancellationReason: string;\n  setCancellationReason: (val: string) => void;\n  submittingCancellation: boolean;\n  cancellationResult: any;\n  closeCancellationModal: () => void;\n  handleSubmitCancellationRequest: () => void;\n}\n\nexport const CancellationRequestModal: React.FC<\n  CancellationRequestModalProps\n> = ({\n  visible,\n  isRTL,\n  selectedCancellationBooking,\n  cancellationReason,\n  setCancellationReason,\n  submittingCancellation,\n  cancellationResult,\n  closeCancellationModal,\n  handleSubmitCancellationRequest,\n}) => {\n  return (\n    <Modal\n      animationType=\"fade\"\n      transparent={true}\n      visible={visible}\n      onRequestClose={closeCancellationModal}\n    >\n      <View\n        style={{\n          flex: 1,\n          backgroundColor: 'rgba(0, 0, 0, 0.5)',\n          justifyContent: 'center',\n          alignItems: 'center',\n          padding: 20,\n        }}\n      >\n        <View\n          style={{\n            backgroundColor: '#fff',\n            borderRadius: 16,\n            width: '100%',\n            maxWidth: 450,\n            maxHeight: '90%',\n            overflow: 'hidden',\n            elevation: 5,\n            shadowColor: '#000',\n            shadowOffset: { width: 0, height: 2 },\n            shadowOpacity: 0.25,\n            shadowRadius: 4,\n          }}\n        >\n          {/* Modal Header */}\n          <View\n            style={{\n              padding: 16,\n              borderBottomWidth: 1,\n              borderBottomColor: '#E2E8F0',\n              flexDirection: isRTL ? 'row-reverse' : 'row',\n              justifyContent: 'space-between',\n              alignItems: 'center',\n            }}\n          >\n            <Text\n              style={{\n                fontSize: 18,\n                fontWeight: '700',\n                color: colors.primary,\n              }}\n            >\n              {isRTL ? 'в•ӘВ¬в”ҳГ©в•ӘВ»в”ҳГЁв”ҳГ  в•Әв•–в”ҳГӨв•ӘВҝ в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ' : 'Request Cancellation'}\n            </Text>\n            <TouchableOpacity\n              onPress={closeCancellationModal}\n              style={{ padding: 4 }}\n            >\n              <Icon name=\"close\" size={22} color=\"#64748B\" />\n            </TouchableOpacity>\n          </View>\n\n          {/* Modal Body */}\n          <ScrollView contentContainerStyle={{ padding: 20 }}>\n            {!cancellationResult ? (\n              <>\n                {/* Policy Banner */}\n                <View\n                  style={{\n                    flexDirection: isRTL ? 'row-reverse' : 'row',\n                    alignItems: 'flex-start',\n                    backgroundColor: '#FFFBEB',\n                    borderWidth: 1,\n                    borderColor: '#FEF3C7',\n                    borderLeftWidth: isRTL ? 1 : 4,\n                    borderRightWidth: isRTL ? 4 : 1,\n                    borderLeftColor: isRTL ? '#FEF3C7' : '#F59E0B',\n                    borderRightColor: isRTL ? '#F59E0B' : '#FEF3C7',\n                    borderRadius: 10,\n                    padding: 12,\n                    marginBottom: 16,\n                    gap: 8,\n                  }}\n                >\n                  <Icon\n                    name=\"information-circle-outline\"\n                    size={16}\n                    color=\"#F59E0B\"\n                    style={{\n                      marginTop: 1,\n                      marginRight: isRTL ? 0 : 2,\n                      marginLeft: isRTL ? 2 : 0,\n                    }}\n                  />\n                  <Text\n                    style={{\n                      color: '#92400E',\n                      fontSize: 13,\n                      lineHeight: 18,\n                      flex: 1,\n                      fontWeight: '500',\n                      textAlign: isRTL ? 'right' : 'left',\n                    }}\n                  >\n                    {isRTL\n                      ? 'в•ӘВ¬в•ӘВ«в•Әв•ўв•Әв•Ј в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВ»в•ӘВәв•ӘВ» в•ӘВәв”ҳГӨв”ҳГ в•ӘВҝв•ӘВәв”ҳГӨв•Әв•‘ в”ҳГӨв”ҳГ в”ҳГӘв•ӘВәв”ҳГјв”ҳГ©в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ в”ҳГӘв•Әв”Ӯв”ҳГЁв•ӘВәв•Әв”Ӯв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв•ӘВ«в•ӘВәв•Әв•Ўв•ӘвҢҗ в•ӘВҝв”ҳГўв”ҳГӨ в”ҳГ в”ҳГ©в•ӘВ»в”ҳГ  в•ӘВ«в•ӘВ»в”ҳГ в•ӘвҢҗ. в•Әв”Ӯв”ҳГЁв•ӘВ¬в”ҳГ  в•ӘВ«в•Әв•Ўв”ҳГ  в•Әв•Јв”ҳГ в”ҳГӘв”ҳГӨв•ӘвҢҗ в”ҳГ в”ҳГҘв•Әв•Ўв•ӘвҢҗ в”ҳГ в•Әв”Ӯв•Әв–’в•ӘвҢҗ в”ҳГ в”ҳГҘ в•ӘВәв”ҳГӨв”ҳГ в•ӘВҝв•ӘВәв”ҳГӨв•Әв•‘ в•ӘВәв”ҳГӨв”ҳГ в•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВ»в•ӘвҢҗ в•ӘВәв”ҳГӨв”ҳГ в•ӘГұв”ҳГ§в”ҳГӨв•ӘвҢҗ.'\n                      : \"Refunds depend on each vendor's cancellation window and are subject to admin approval. Masarra's commission is deducted from eligible refunds.\"}\n                  </Text>\n                </View>\n\n                {/* Vendor Cancellation Policies & Time Left */}\n                {selectedCancellationBooking?.services && (\n                  <View style={{ marginBottom: 16 }}>\n                    <Text\n                      style={{\n                        fontSize: 14,\n                        fontWeight: '700',\n                        color: '#1E293B',\n                        marginBottom: 8,\n                        textAlign: isRTL ? 'right' : 'left',\n                      }}\n                    >\n                      {isRTL\n                        ? 'в•ӘВ¬в”ҳГјв•ӘВәв•Әв•Ўв”ҳГЁв”ҳГӨ в•Әв”Ӯв”ҳГЁв•ӘВәв•Әв”Ӯв•ӘвҢҗ в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв•ӘВ«в•ӘВ»в”ҳГ в•ӘВәв•ӘВ¬:'\n                        : 'Service cancellation details:'}\n                    </Text>\n                    {selectedCancellationBooking.services.map(\n                      (svc: any, idx: number) => {\n                        const serviceName = isRTL\n                          ? svc.service?.nameAr ||\n                            svc.service?.name ||\n                            svc.service\n                          : svc.service?.name || svc.service;\n                        const vendorName = isRTL\n                          ? svc.vendor?.vendorProfile?.businessName_ar ||\n                            svc.vendor?.vendorProfile?.businessName ||\n                            svc.vendor?.name\n                          : svc.vendor?.vendorProfile?.businessName ||\n                            svc.vendor?.name;\n\n                        const refundPeriodHours =\n                          svc.vendor?.vendorProfile?.refundPeriodHours !==\n                          undefined\n                            ? Number(svc.vendor.vendorProfile.refundPeriodHours)\n                            : 48;\n\n                        const formatRefundWindow = (h: number) => {\n                          if (h === 0) return isRTL ? 'в•ӘГәв”ҳГЁ в”ҳГӘв”ҳГ©в•ӘВ¬' : 'any time';\n                          if (h < 24) return isRTL ? `${h} в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘвҢҗ` : `${h} hours`;\n                          const d = Math.round(h / 24);\n                          return isRTL ? `${d} в”ҳГЁв”ҳГӘв”ҳГ ` : `${d} days`;\n                        };\n\n                        // Calculate cutoff date & time left\n                        const eventTimeStr =\n                          svc.timeSlot?.start ||\n                          svc.eventDate ||\n                          selectedCancellationBooking.eventTime?.start ||\n                          selectedCancellationBooking.eventDate;\n                        let cutoffDate: Date | null = null;\n                        let isWithinWindow = false;\n                        let timeLeftString = '';\n\n                        if (eventTimeStr) {\n                          const d = new Date(eventTimeStr);\n                          if (\n                            d.getUTCHours() === 0 &&\n                            d.getUTCMinutes() === 0 &&\n                            d.getUTCSeconds() === 0 &&\n                            d.getUTCMilliseconds() === 0\n                          ) {\n                            d.setUTCHours(20, 59, 59, 999); // 23:59:59 Kuwait time\n                          }\n                          cutoffDate = new Date(\n                            d.getTime() - refundPeriodHours * 60 * 60 * 1000,\n                          );\n                          const now = new Date();\n                          isWithinWindow =\n                            now.getTime() <= cutoffDate.getTime();\n\n                          if (isWithinWindow) {\n                            const diffMs = cutoffDate.getTime() - now.getTime();\n                            const totalHours = Math.floor(\n                              diffMs / (1000 * 60 * 60),\n                            );\n                            if (totalHours < 24) {\n                              timeLeftString = isRTL\n                                ? `в”ҳГ в•ӘВ¬в•ӘВҝв”ҳГ©в”ҳГЁ ${totalHours} в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘвҢҗ в”ҳГӨв”ҳГӨв•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв”ҳГ в•ӘВјв•ӘВәв”ҳГҘв”ҳГЁ`\n                                : `${totalHours} hours left for free cancellation`;\n                            } else {\n                              const days = Math.floor(totalHours / 24);\n                              const remainingHours = totalHours % 24;\n                              timeLeftString = isRTL\n                                ? `в”ҳГ в•ӘВ¬в•ӘВҝв”ҳГ©в”ҳГЁ ${days} в”ҳГЁв”ҳГӘв”ҳГ  в”ҳГӘ ${remainingHours} в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘвҢҗ в”ҳГӨв”ҳГӨв•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв”ҳГ в•ӘВјв•ӘВәв”ҳГҘв”ҳГЁ`\n                                : `${days}d ${remainingHours}h left for free cancellation`;\n                            }\n                          } else {\n                            timeLeftString = isRTL\n                              ? 'в•ӘВәв”ҳГҘв•ӘВ¬в”ҳГ§в•ӘВ¬ в”ҳГјв•ӘВ¬в•Әв–’в•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв”ҳГ в•ӘВјв•ӘВәв”ҳГҘв”ҳГЁ'\n                              : 'Free cancellation period expired';\n                          }\n                        }\n\n                        return (\n                          <View\n                            key={svc._id || idx}\n                            style={{\n                              backgroundColor: '#F8FAFC',\n                              borderWidth: 1,\n                              borderColor: '#E2E8F0',\n                              borderRadius: 10,\n                              padding: 12,\n                              marginBottom: 10,\n                              alignItems: 'stretch',\n                            }}\n                          >\n                            <View\n                              style={{\n                                flexDirection: isRTL ? 'row-reverse' : 'row',\n                                justifyContent: 'space-between',\n                                alignItems: 'center',\n                                marginBottom: 6,\n                              }}\n                            >\n                              <Text\n                                style={{\n                                  fontSize: 13,\n                                  fontWeight: '700',\n                                  color: '#334155',\n                                  flex: 1,\n                                  textAlign: isRTL ? 'right' : 'left',\n                                }}\n                              >\n                                {serviceName}\n                              </Text>\n                              {vendorName && (\n                                <Text\n                                  style={{\n                                    fontSize: 11,\n                                    color: '#64748B',\n                                    fontWeight: '500',\n                                    marginRight: isRTL ? 0 : 4,\n                                    marginLeft: isRTL ? 4 : 0,\n                                  }}\n                                >\n                                  ({vendorName})\n                                </Text>\n                              )}\n                            </View>\n\n                            <View\n                              style={{\n                                flexDirection: isRTL ? 'row-reverse' : 'row',\n                                alignItems: 'center',\n                                gap: 6,\n                                marginBottom: 6,\n                              }}\n                            >\n                              <Icon\n                                name=\"time-outline\"\n                                size={14}\n                                color=\"#64748B\"\n                              />\n                              <Text\n                                style={{\n                                  fontSize: 11,\n                                  color: '#475569',\n                                  textAlign: isRTL ? 'right' : 'left',\n                                  flex: 1,\n                                }}\n                              >\n                                {isRTL\n                                  ? `в•Әв”Ӯв”ҳГЁв•ӘВәв•Әв”Ӯв•ӘвҢҗ в•ӘВәв”ҳГӨв•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ: в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВ»в•ӘВәв•ӘВ» в”ҳГўв•ӘВәв”ҳГ в”ҳГӨ в•ӘВЎв•ӘВ¬в”ҳГ« ${formatRefundWindow(\n                                      refundPeriodHours,\n                                    )} в”ҳГ©в•ӘВҝв”ҳГӨ в•ӘВәв”ҳГӨв”ҳГјв•Әв•Јв•ӘВәв”ҳГӨв”ҳГЁв•ӘвҢҗ`\n                                  : `Cancellation Policy: Full refund up to ${formatRefundWindow(\n                                      refundPeriodHours,\n                                    )} before event`}\n                              </Text>\n                            </View>\n\n                            {timeLeftString ? (\n                              <View\n                                style={{\n                                  flexDirection: isRTL ? 'row-reverse' : 'row',\n                                  alignItems: 'center',\n                                  backgroundColor: isWithinWindow\n                                    ? '#ECFDF5'\n                                    : '#FEF2F2',\n                                  paddingVertical: 6,\n                                  paddingHorizontal: 8,\n                                  borderRadius: 6,\n                                  gap: 6,\n                                }}\n                              >\n                                <Icon\n                                  name={\n                                    isWithinWindow\n                                      ? 'checkmark-circle'\n                                      : 'alert-circle'\n                                  }\n                                  size={14}\n                                  color={isWithinWindow ? '#059669' : '#DC2626'}\n                                />\n                                <Text\n                                  style={{\n                                    fontSize: 11,\n                                    fontWeight: '600',\n                                    color: isWithinWindow\n                                      ? '#047857'\n                                      : '#B91C1C',\n                                    flex: 1,\n                                    textAlign: isRTL ? 'right' : 'left',\n                                  }}\n                                >\n                                  {timeLeftString}\n                                </Text>\n                              </View>\n                            ) : null}\n                          </View>\n                        );\n                      },\n                    )}\n                  </View>\n                )}\n\n                {/* Input Label */}\n                <View\n                  style={{\n                    flexDirection: isRTL ? 'row-reverse' : 'row',\n                    marginBottom: 8,\n                  }}\n                >\n                  <Text\n                    style={{\n                      fontSize: 14,\n                      fontWeight: '600',\n                      color: '#374151',\n                    }}\n                  >\n                    {isRTL ? 'в•Әв”Ӯв•ӘВҝв•ӘВҝ в•ӘВәв”ҳГӨв•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ' : 'Reason for cancellation'}\n                  </Text>\n                  <Text style={{ color: '#dc3545', marginLeft: 4 }}> *</Text>\n                </View>\n\n                {/* Text Input */}\n                <TextInput\n                  multiline={true}\n                  numberOfLines={4}\n                  value={cancellationReason}\n                  onChangeText={setCancellationReason}\n                  placeholder={\n                    isRTL\n                      ? 'в•ӘГәв•ӘВ«в•ӘВҝв•Әв–’в”ҳГҘв•ӘВә в•Әв•Јв”ҳГҘ в•Әв”Ӯв•ӘВҝв•ӘВҝ в•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ в•ӘВәв”ҳГӨв•ӘВЎв•ӘВјв•Әв–“...'\n                      : \"Tell us why you're cancellingО“ГҮВӘ\"\n                  }\n                  placeholderTextColor=\"#94A3B8\"\n                  style={{\n                    borderWidth: 1,\n                    borderColor: '#E2E8F0',\n                    borderRadius: 8,\n                    padding: 12,\n                    fontSize: 14,\n                    color: '#0F172A',\n                    height: 100,\n                    textAlignVertical: 'top',\n                    textAlign: isRTL ? 'right' : 'left',\n                    marginBottom: 20,\n                  }}\n                />\n\n                {/* Modal Footer Buttons */}\n                <View\n                  style={{\n                    flexDirection: isRTL ? 'row-reverse' : 'row',\n                    justifyContent: 'flex-end',\n                    gap: 12,\n                  }}\n                >\n                  <TouchableOpacity\n                    onPress={closeCancellationModal}\n                    style={{\n                      paddingVertical: 10,\n                      paddingHorizontal: 16,\n                      borderRadius: 10,\n                      borderWidth: 1,\n                      borderColor: '#CBD5E1',\n                      backgroundColor: '#fff',\n                    }}\n                  >\n                    <Text\n                      style={{\n                        fontSize: 14,\n                        fontWeight: '600',\n                        color: '#475569',\n                      }}\n                    >\n                      {isRTL ? 'в•ӘГ‘в•Әв•‘в”ҳГӨв•ӘВәв”ҳГ©' : 'Close'}\n                    </Text>\n                  </TouchableOpacity>\n\n                  <TouchableOpacity\n                    onPress={handleSubmitCancellationRequest}\n                    disabled={\n                      !cancellationReason.trim() || submittingCancellation\n                    }\n                    style={{\n                      paddingVertical: 10,\n                      paddingHorizontal: 16,\n                      borderRadius: 10,\n                      backgroundColor: '#EF4444',\n                      opacity:\n                        !cancellationReason.trim() || submittingCancellation\n                          ? 0.6\n                          : 1,\n                      justifyContent: 'center',\n                      alignItems: 'center',\n                      minWidth: 120,\n                    }}\n                  >\n                    {submittingCancellation ? (\n                      <ActivityIndicator size=\"small\" color=\"#fff\" />\n                    ) : (\n                      <Text\n                        style={{\n                          fontSize: 14,\n                          fontWeight: '600',\n                          color: '#fff',\n                        }}\n                      >\n                        {isRTL ? 'в•ӘГ‘в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в•ӘВәв”ҳГӨв•Әв•–в”ҳГӨв•ӘВҝ' : 'Submit request'}\n                      </Text>\n                    )}\n                  </TouchableOpacity>\n                </View>\n              </>\n            ) : cancellationResult.error ? (\n              <View style={{ alignItems: 'center', width: '100%' }}>\n                {/* Error Alert */}\n                <View\n                  style={{\n                    flexDirection: isRTL ? 'row-reverse' : 'row',\n                    alignItems: 'center',\n                    backgroundColor: '#FEF2F2',\n                    borderWidth: 1,\n                    borderColor: '#FEE2E2',\n                    borderLeftWidth: isRTL ? 1 : 4,\n                    borderRightWidth: isRTL ? 4 : 1,\n                    borderLeftColor: isRTL ? '#FEE2E2' : '#EF4444',\n                    borderRightColor: isRTL ? '#EF4444' : '#FEE2E2',\n                    borderRadius: 10,\n                    padding: 16,\n                    width: '100%',\n                    marginBottom: 20,\n                    gap: 8,\n                  }}\n                >\n                  <Icon name=\"alert-circle-outline\" size={18} color=\"#EF4444\" />\n                  <Text\n                    style={{\n                      color: '#991B1B',\n                      fontSize: 14,\n                      fontWeight: '600',\n                      flex: 1,\n                      textAlign: isRTL ? 'right' : 'left',\n                    }}\n                  >\n                    {cancellationResult.error}\n                  </Text>\n                </View>\n\n                <TouchableOpacity\n                  onPress={closeCancellationModal}\n                  style={{\n                    paddingVertical: 10,\n                    paddingHorizontal: 24,\n                    borderRadius: 10,\n                    backgroundColor: colors.primary,\n                    shadowColor: colors.primary,\n                    shadowOffset: { width: 0, height: 2 },\n                    shadowOpacity: 0.15,\n                    shadowRadius: 4,\n                    elevation: 2,\n                  }}\n                >\n                  <Text\n                    style={{\n                      fontSize: 14,\n                      fontWeight: '600',\n                      color: '#fff',\n                    }}\n                  >\n                    {isRTL ? 'в•ӘГ‘в•Әв•‘в”ҳГӨв•ӘВәв”ҳГ©' : 'Close'}\n                  </Text>\n                </TouchableOpacity>\n              </View>\n            ) : (\n              <View style={{ alignItems: 'center', width: '100%' }}>\n                {/* Success Alert */}\n                <View\n                  style={{\n                    flexDirection: isRTL ? 'row-reverse' : 'row',\n                    alignItems: 'center',\n                    backgroundColor: '#F0FDF4',\n                    borderWidth: 1,\n                    borderColor: '#DCFCE7',\n                    borderLeftWidth: isRTL ? 1 : 4,\n                    borderRightWidth: isRTL ? 4 : 1,\n                    borderLeftColor: isRTL ? '#DCFCE7' : '#22C55E',\n                    borderRightColor: isRTL ? '#22C55E' : '#DCFCE7',\n                    borderRadius: 10,\n                    padding: 16,\n                    width: '100%',\n                    marginBottom: 16,\n                    gap: 8,\n                  }}\n                >\n                  <Icon\n                    name=\"checkmark-circle-outline\"\n                    size={18}\n                    color=\"#22C55E\"\n                  />\n                  <Text\n                    style={{\n                      color: '#166534',\n                      fontSize: 14,\n                      fontWeight: '600',\n                      flex: 1,\n                      textAlign: isRTL ? 'right' : 'left',\n                      lineHeight: 20,\n                    }}\n                  >\n                    {isRTL\n                      ? 'в•ӘВ¬в”ҳГ  в•ӘВ¬в”ҳГ©в•ӘВ»в”ҳГЁв”ҳГ  в•Әв•–в”ҳГӨв•ӘВҝ в•ӘВәв”ҳГӨв•ӘГ‘в”ҳГӨв•Әв•‘в•ӘВәв•ӘГӯ в•ӘВҝв”ҳГҘв•ӘВјв•ӘВәв•ӘВЎ в”ҳГӘв•ӘВјв•ӘВәв•Әв–’в”ҳГЁ в”ҳГ в•Әв–’в•ӘВәв•ӘВјв•Әв•Јв•ӘВ¬в”ҳГ§ в”ҳГ в”ҳГҘ в”ҳГ©в•ӘВҝв”ҳГӨ в•ӘВәв”ҳГӨв•ӘГ‘в•ӘВ»в•ӘВәв•Әв–’в•ӘвҢҗ.'\n                      : 'Your cancellation request has been submitted for review.'}\n                  </Text>\n                </View>\n\n                {/* Refund Eli